<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- About Content -->
  <div class="space-y-5">
    <form method="POST" action="/admin/about/save">
      <div class="bg-white rounded-xl shadow-sm p-6">
        <h3 class="font-bold text-gray-800 mb-5 flex items-center gap-2"><i class="fas fa-info-circle text-blue-600"></i> About Page Content</h3>

        <!-- Mission -->
        <div class="mb-5">
          <h4 class="font-semibold text-gray-700 text-sm mb-3 flex items-center gap-1.5"><i class="fas fa-bullseye text-blue-500 text-xs"></i> Mission</h4>
          <div class="space-y-2">
            <textarea name="mission_uz" rows="3" placeholder="Missiya (UZ)" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"><%= about.mission_uz || '' %></textarea>
            <textarea name="mission_ru" rows="3" placeholder="Миссия (RU)" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"><%= about.mission_ru || '' %></textarea>
            <textarea name="mission_en" rows="3" placeholder="Mission (EN)" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"><%= about.mission_en || '' %></textarea>
          </div>
        </div>

        <!-- Vision -->
        <div class="mb-5">
          <h4 class="font-semibold text-gray-700 text-sm mb-3 flex items-center gap-1.5"><i class="fas fa-eye text-green-500 text-xs"></i> Vision</h4>
          <div class="space-y-2">
            <textarea name="vision_uz" rows="3" placeholder="Vizyon (UZ)" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"><%= about.vision_uz || '' %></textarea>
            <textarea name="vision_ru" rows="3" placeholder="Видение (RU)" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"><%= about.vision_ru || '' %></textarea>
            <textarea name="vision_en" rows="3" placeholder="Vision (EN)" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"><%= about.vision_en || '' %></textarea>
          </div>
        </div>

        <!-- History -->
        <div class="mb-5">
          <h4 class="font-semibold text-gray-700 text-sm mb-3 flex items-center gap-1.5"><i class="fas fa-history text-purple-500 text-xs"></i> History</h4>
          <div class="space-y-2">
            <textarea name="history_uz" rows="4" placeholder="Tarix (UZ)" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"><%= about.history_uz || '' %></textarea>
            <textarea name="history_ru" rows="4" placeholder="История (RU)" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"><%= about.history_ru || '' %></textarea>
            <textarea name="history_en" rows="4" placeholder="History (EN)" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"><%= about.history_en || '' %></textarea>
          </div>
        </div>

        <button type="submit" class="px-6 py-2.5 bg-blue-900 text-white rounded-lg text-sm font-semibold hover:bg-blue-800">
          <i class="fas fa-save mr-1.5"></i> Save Content
        </button>
      </div>
    </form>
  </div>

  <!-- Directors -->
  <div class="space-y-5">
    <!-- Add Director -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h3 class="font-bold text-gray-800 mb-4 flex items-center gap-2"><i class="fas fa-user-tie text-blue-600"></i> Add Director</h3>
      <form method="POST" action="/admin/about/directors/add" enctype="multipart/form-data" class="space-y-3">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Full Name *</label>
            <input type="text" name="name" required class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Order</label>
            <input type="number" name="order" value="0" min="0" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1.5">Position (UZ)</label>
          <input type="text" name="position_uz" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1.5">Position (RU)</label>
          <input type="text" name="position_ru" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1.5">Position (EN)</label>
          <input type="text" name="position_en" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1.5">Photo</label>
          <input type="file" name="image" accept="image/*" class="border rounded-lg px-3 py-2 text-sm w-full file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:bg-blue-50 file:text-blue-700">
        </div>
        <button type="submit" class="w-full py-2.5 bg-blue-900 text-white rounded-lg text-sm font-semibold hover:bg-blue-800">
          <i class="fas fa-plus mr-1.5"></i> Add Director
        </button>
      </form>
    </div>

    <!-- Directors List -->
    <div class="bg-white rounded-xl shadow-sm p-5">
      <h3 class="font-bold text-gray-800 mb-4">Directors List</h3>
      <% if (!about.directors || about.directors.length === 0) { %>
        <p class="text-gray-400 text-sm text-center py-6">No directors added yet</p>
      <% } %>
      <div class="space-y-3">
        <% (about.directors || []).forEach(d => { %>
          <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl">
            <% if (d.image) { %>
              <img src="<%= d.image %>" class="w-12 h-12 rounded-xl object-cover flex-shrink-0">
            <% } else { %>
              <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center text-blue-600 flex-shrink-0">
                <i class="fas fa-user"></i>
              </div>
            <% } %>
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-gray-800 text-sm"><%= d.name %></p>
              <p class="text-gray-500 text-xs truncate"><%= d.position_uz || d.position_en || '' %></p>
            </div>
            <form method="POST" action="/admin/about/directors/<%= d._id %>/delete" onsubmit="return confirm('Delete director?')">
              <button type="submit" class="w-8 h-8 rounded-lg bg-red-50 hover:bg-red-100 flex items-center justify-center text-red-500">
                <i class="fas fa-trash text-xs"></i>
              </button>
            </form>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>
