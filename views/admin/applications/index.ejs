<div class="flex gap-3 mb-5">
  <a href="/admin/applications" class="px-3 py-1.5 rounded-lg text-sm font-medium <%= !query.status ? 'bg-blue-900 text-white' : 'bg-white text-gray-600 border hover:bg-gray-50' %>">All</a>
  <a href="/admin/applications?status=pending" class="px-3 py-1.5 rounded-lg text-sm font-medium <%= query.status==='pending' ? 'bg-yellow-500 text-white' : 'bg-white text-gray-600 border hover:bg-gray-50' %>">Pending</a>
  <a href="/admin/applications?status=accepted" class="px-3 py-1.5 rounded-lg text-sm font-medium <%= query.status==='accepted' ? 'bg-green-600 text-white' : 'bg-white text-gray-600 border hover:bg-gray-50' %>">Accepted</a>
  <a href="/admin/applications?status=rejected" class="px-3 py-1.5 rounded-lg text-sm font-medium <%= query.status==='rejected' ? 'bg-red-500 text-white' : 'bg-white text-gray-600 border hover:bg-gray-50' %>">Rejected</a>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">#</th>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Name</th>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Phone</th>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Birth Date</th>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Status</th>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Applied</th>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% if (apps.length === 0) { %>
        <tr><td colspan="7" class="px-6 py-12 text-center text-gray-400"><i class="fas fa-file-alt text-3xl mb-2 block"></i>No applications</td></tr>
      <% } %>
      <% apps.forEach((a, i) => { %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 text-gray-400 text-xs"><%= i + 1 %></td>
          <td class="px-6 py-4 font-medium text-gray-800"><%= a.first_name %> <%= a.last_name %></td>
          <td class="px-6 py-4 text-gray-600"><%= a.phone %></td>
          <td class="px-6 py-4 text-gray-600"><%= new Date(a.birth_date).toLocaleDateString() %></td>
          <td class="px-6 py-4">
            <span class="text-xs px-2.5 py-1 rounded-full font-medium
              <%= a.status==='accepted'?'bg-green-100 text-green-700':a.status==='rejected'?'bg-red-100 text-red-700':'bg-yellow-100 text-yellow-700' %>">
              <%= a.status %>
            </span>
          </td>
          <td class="px-6 py-4 text-gray-400 text-xs"><%= a.createdAt.toLocaleDateString() %></td>
          <td class="px-6 py-4">
            <div class="flex gap-2">
              <button onclick="showStatusModal('<%= a._id %>', '<%= a.status %>', '<%= (a.notes||'').replace(/'/g, "\\'") %>')"
                class="px-3 py-1.5 text-xs bg-blue-50 text-blue-700 hover:bg-blue-100 rounded-lg font-medium">
                <i class="fas fa-edit mr-1"></i> Update
              </button>
              <form method="POST" action="/admin/applications/<%= a._id %>/delete" onsubmit="return confirm('Delete?')">
                <button type="submit" class="w-7 h-7 rounded-lg bg-red-50 hover:bg-red-100 flex items-center justify-center text-red-600">
                  <i class="fas fa-trash text-xs"></i>
                </button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Status Modal -->
<div id="statusModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl max-w-md w-full p-6">
    <h3 class="font-bold text-gray-800 text-lg mb-5">Update Application Status</h3>
    <form id="statusForm" method="POST">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-2">Status</label>
        <select name="status" id="statusSelect" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="pending">Pending</option>
          <option value="accepted">Accepted</option>
          <option value="rejected">Rejected</option>
        </select>
      </div>
      <div class="mb-5">
        <label class="block text-sm font-medium text-gray-700 mb-2">Notes</label>
        <textarea name="notes" id="statusNotes" rows="3" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
      </div>
      <div class="flex gap-3">
        <button type="submit" class="flex-1 py-2.5 bg-blue-900 text-white rounded-lg text-sm font-semibold hover:bg-blue-800">Update</button>
        <button type="button" onclick="closeStatusModal()" class="flex-1 py-2.5 border text-gray-600 rounded-lg text-sm font-medium hover:bg-gray-50">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
function showStatusModal(id, status, notes) {
  document.getElementById('statusForm').action = `/admin/applications/${id}/status`;
  document.getElementById('statusSelect').value = status;
  document.getElementById('statusNotes').value = notes;
  document.getElementById('statusModal').classList.remove('hidden');
}
function closeStatusModal() { document.getElementById('statusModal').classList.add('hidden'); }
</script>
