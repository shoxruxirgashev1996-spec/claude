<!-- Summary Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-6">
  <div class="bg-white rounded-xl shadow-sm p-5 border-l-4 border-green-500">
    <p class="text-gray-500 text-xs font-medium uppercase tracking-wider">Total Income</p>
    <p class="text-2xl font-bold text-green-600 mt-1"><%= income.toLocaleString() %> UZS</p>
  </div>
  <div class="bg-white rounded-xl shadow-sm p-5 border-l-4 border-red-400">
    <p class="text-gray-500 text-xs font-medium uppercase tracking-wider">Total Expense</p>
    <p class="text-2xl font-bold text-red-500 mt-1"><%= expense.toLocaleString() %> UZS</p>
  </div>
  <div class="bg-white rounded-xl shadow-sm p-5 border-l-4 border-blue-500">
    <p class="text-gray-500 text-xs font-medium uppercase tracking-wider">Balance</p>
    <p class="text-2xl font-bold <%= (income-expense)>=0?'text-green-600':'text-red-500' %> mt-1"><%= (income-expense).toLocaleString() %> UZS</p>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
  <!-- Add Form -->
  <div class="bg-white rounded-xl shadow-sm p-5">
    <h3 class="font-bold text-gray-800 mb-4 flex items-center gap-2"><i class="fas fa-plus-circle text-blue-600"></i> Add Record</h3>
    <form method="POST" action="/admin/budget/create" class="space-y-3">
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Type *</label>
        <select name="type" required class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="income">Income</option>
          <option value="expense">Expense</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Category (UZ) *</label>
        <input type="text" name="category_uz" required placeholder="Daromad turi" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Category (RU)</label>
        <input type="text" name="category_ru" placeholder="Категория" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Category (EN)</label>
        <input type="text" name="category_en" placeholder="Category" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Amount (UZS) *</label>
        <input type="number" name="amount" required min="0" placeholder="0" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Date *</label>
        <input type="date" name="date" required value="<%= new Date().toISOString().split('T')[0] %>" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Description (UZ)</label>
        <textarea name="description_uz" rows="2" placeholder="Izoh" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
      </div>
      <button type="submit" class="w-full py-2.5 bg-blue-900 text-white rounded-lg text-sm font-semibold hover:bg-blue-800">
        <i class="fas fa-plus mr-1.5"></i> Add Record
      </button>
    </form>
  </div>

  <!-- Chart -->
  <div class="lg:col-span-2 bg-white rounded-xl shadow-sm p-5">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-bold text-gray-800">Monthly Overview</h3>
      <form method="GET" class="flex gap-2">
        <select name="year" onchange="this.form.submit()" class="border rounded-lg px-3 py-1.5 text-sm">
          <% years.forEach(y => { %><option value="<%= y %>" <%= y===year?'selected':'' %>><%= y %></option><% }) %>
          <% if (!years.includes(new Date().getFullYear())) { %><option value="<%= new Date().getFullYear() %>" selected><%= new Date().getFullYear() %></option><% } %>
        </select>
      </form>
    </div>
    <canvas id="budgetChart" height="220"></canvas>
  </div>
</div>

<!-- Table -->
<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <div class="px-6 py-4 border-b flex items-center justify-between">
    <h3 class="font-bold text-gray-800">Records for <%= year %></h3>
    <form method="GET" class="flex gap-2">
      <input type="hidden" name="year" value="<%= year %>">
      <select name="type" onchange="this.form.submit()" class="border rounded-lg px-3 py-1.5 text-sm">
        <option value="">All Types</option>
        <option value="income" <%= query.type==='income'?'selected':'' %>>Income</option>
        <option value="expense" <%= query.type==='expense'?'selected':'' %>>Expense</option>
      </select>
    </form>
  </div>
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Date</th>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Type</th>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Category</th>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Amount</th>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% if (budgets.length === 0) { %>
        <tr><td colspan="5" class="px-6 py-10 text-center text-gray-400">No records for this year</td></tr>
      <% } %>
      <% budgets.forEach(b => { %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-3 text-gray-500 text-xs"><%= new Date(b.date).toLocaleDateString() %></td>
          <td class="px-6 py-3"><span class="text-xs px-2 py-1 rounded-full font-medium <%= b.type==='income'?'bg-green-100 text-green-700':'bg-red-100 text-red-600' %>"><%= b.type %></span></td>
          <td class="px-6 py-3 text-gray-700"><%= b.category_uz %></td>
          <td class="px-6 py-3 font-semibold <%= b.type==='income'?'text-green-600':'text-red-500' %>"><%= b.amount.toLocaleString() %> UZS</td>
          <td class="px-6 py-3">
            <form method="POST" action="/admin/budget/<%= b._id %>/delete" onsubmit="return confirm('Delete this record?')">
              <button type="submit" class="w-8 h-8 rounded-lg bg-red-50 hover:bg-red-100 flex items-center justify-center text-red-600">
                <i class="fas fa-trash text-xs"></i>
              </button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<script>
const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const monthlyData = <%- JSON.stringify(monthly) %>;
const incomeData = Array(12).fill(0);
const expenseData = Array(12).fill(0);
monthlyData.forEach(d => {
  if (d._id.type === 'income') incomeData[d._id.month - 1] = d.total;
  else expenseData[d._id.month - 1] = d.total;
});

new Chart(document.getElementById('budgetChart'), {
  type: 'bar',
  data: {
    labels: months,
    datasets: [
      { label: 'Income', data: incomeData, backgroundColor: 'rgba(16,185,129,0.8)', borderRadius: 4 },
      { label: 'Expense', data: expenseData, backgroundColor: 'rgba(239,68,68,0.7)', borderRadius: 4 }
    ]
  },
  options: { responsive: true, scales: { y: { beginAtZero: true } }, plugins: { legend: { position: 'top' } } }
});
</script>
