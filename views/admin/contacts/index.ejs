<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Name</th>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Email</th>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Message</th>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Status</th>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Date</th>
        <th class="text-left px-6 py-3 text-gray-500 font-semibold text-xs uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% if (contacts.length === 0) { %>
        <tr><td colspan="6" class="px-6 py-12 text-center text-gray-400"><i class="fas fa-envelope text-3xl mb-2 block"></i>No messages yet</td></tr>
      <% } %>
      <% contacts.forEach(c => { %>
        <tr class="hover:bg-gray-50 <%= !c.isRead ? 'bg-blue-50/30' : '' %>">
          <td class="px-6 py-4">
            <div class="flex items-center gap-2">
              <% if (!c.isRead) { %><span class="w-2 h-2 bg-blue-500 rounded-full flex-shrink-0"></span><% } %>
              <span class="font-medium text-gray-800"><%= c.name %></span>
            </div>
          </td>
          <td class="px-6 py-4 text-gray-600"><%= c.email %></td>
          <td class="px-6 py-4 text-gray-600 max-w-xs">
            <p class="truncate text-sm"><%= c.message.substring(0, 80) %><%= c.message.length > 80 ? '...' : '' %></p>
          </td>
          <td class="px-6 py-4">
            <span class="text-xs px-2 py-1 rounded-full <%= c.isRead ? 'bg-gray-100 text-gray-500' : 'bg-blue-100 text-blue-700 font-semibold' %>">
              <%= c.isRead ? 'Read' : 'New' %>
            </span>
          </td>
          <td class="px-6 py-4 text-gray-400 text-xs"><%= c.createdAt.toLocaleDateString() %></td>
          <td class="px-6 py-4">
            <div class="flex gap-2">
              <% if (!c.isRead) { %>
                <form method="POST" action="/admin/contacts/<%= c._id %>/read">
                  <button type="submit" class="w-8 h-8 rounded-lg bg-blue-50 hover:bg-blue-100 flex items-center justify-center text-blue-600" title="Mark read">
                    <i class="fas fa-check text-xs"></i>
                  </button>
                </form>
              <% } %>
              <button onclick="showMessage('<%= c.name.replace(/'/g, "\\'") %>', '<%= c.email %>', `<%= c.message.replace(/`/g, '\\`') %>`)" class="w-8 h-8 rounded-lg bg-gray-100 hover:bg-gray-200 flex items-center justify-center text-gray-600" title="View">
                <i class="fas fa-eye text-xs"></i>
              </button>
              <form method="POST" action="/admin/contacts/<%= c._id %>/delete" onsubmit="return confirm('Delete this message?')">
                <button type="submit" class="w-8 h-8 rounded-lg bg-red-50 hover:bg-red-100 flex items-center justify-center text-red-600" title="Delete">
                  <i class="fas fa-trash text-xs"></i>
                </button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Message Modal -->
<div id="modal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl max-w-lg w-full p-6">
    <div class="flex justify-between items-start mb-4">
      <div>
        <h3 id="modal-name" class="font-bold text-gray-800 text-lg"></h3>
        <p id="modal-email" class="text-gray-500 text-sm"></p>
      </div>
      <button onclick="closeModal()" class="w-8 h-8 rounded-lg bg-gray-100 hover:bg-gray-200 flex items-center justify-center">
        <i class="fas fa-times text-gray-600 text-sm"></i>
      </button>
    </div>
    <div class="bg-gray-50 rounded-xl p-4">
      <p id="modal-message" class="text-gray-700 text-sm leading-relaxed whitespace-pre-wrap"></p>
    </div>
  </div>
</div>

<script>
function showMessage(name, email, msg) {
  document.getElementById('modal-name').textContent = name;
  document.getElementById('modal-email').textContent = email;
  document.getElementById('modal-message').textContent = msg;
  document.getElementById('modal').classList.remove('hidden');
}
function closeModal() { document.getElementById('modal').classList.add('hidden'); }
document.getElementById('modal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});
</script>
