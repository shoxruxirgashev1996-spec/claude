<!-- Stats -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-5 mb-6">
  <div class="bg-white rounded-2xl shadow-sm p-5 border-l-4 border-blue-600">
    <p class="text-gray-400 text-xs font-semibold uppercase tracking-wider">Yangiliklar</p>
    <p class="text-3xl font-black text-gray-800 mt-1"><%= stats.totalNews %></p>
    <a href="/admin/news" class="text-blue-600 text-xs mt-2 inline-flex items-center gap-1 hover:underline">
      Barchasi <i class="fas fa-arrow-right text-xs"></i>
    </a>
  </div>
  <div class="bg-white rounded-2xl shadow-sm p-5 border-l-4 border-green-500">
    <p class="text-gray-400 text-xs font-semibold uppercase tracking-wider">Arizalar</p>
    <p class="text-3xl font-black text-gray-800 mt-1"><%= stats.totalApplications %></p>
    <p class="text-orange-500 text-xs mt-1"><i class="fas fa-clock mr-1"></i><%= stats.pendingApps %> kutmoqda</p>
  </div>
  <div class="bg-white rounded-2xl shadow-sm p-5 border-l-4 border-purple-500">
    <p class="text-gray-400 text-xs font-semibold uppercase tracking-wider">Xabarlar</p>
    <p class="text-3xl font-black text-gray-800 mt-1"><%= stats.totalContacts %></p>
    <p class="text-red-500 text-xs mt-1"><i class="fas fa-circle text-xs mr-1"></i><%= stats.unreadContacts %> yangi</p>
  </div>
  <div class="bg-white rounded-2xl shadow-sm p-5 border-l-4 border-yellow-500">
    <p class="text-gray-400 text-xs font-semibold uppercase tracking-wider">Galereya</p>
    <p class="text-3xl font-black text-gray-800 mt-1"><%= stats.totalGallery %></p>
    <a href="/admin/gallery" class="text-yellow-600 text-xs mt-2 inline-flex items-center gap-1 hover:underline">
      Barchasi <i class="fas fa-arrow-right text-xs"></i>
    </a>
  </div>
</div>

<!-- Budget -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-6">
  <div class="bg-white rounded-2xl shadow-sm p-5">
    <div class="flex items-center gap-3 mb-2">
      <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center"><i class="fas fa-arrow-down text-green-500"></i></div>
      <p class="text-gray-400 text-xs font-semibold uppercase tracking-wider">Jami daromad</p>
    </div>
    <p class="text-2xl font-black text-green-600"><%= (stats.income||0).toLocaleString() %> <span class="text-sm font-normal text-gray-400">UZS</span></p>
  </div>
  <div class="bg-white rounded-2xl shadow-sm p-5">
    <div class="flex items-center gap-3 mb-2">
      <div class="w-10 h-10 bg-red-50 rounded-xl flex items-center justify-center"><i class="fas fa-arrow-up text-red-400"></i></div>
      <p class="text-gray-400 text-xs font-semibold uppercase tracking-wider">Jami xarajat</p>
    </div>
    <p class="text-2xl font-black text-red-500"><%= (stats.expense||0).toLocaleString() %> <span class="text-sm font-normal text-gray-400">UZS</span></p>
  </div>
  <div class="bg-white rounded-2xl shadow-sm p-5">
    <div class="flex items-center gap-3 mb-2">
      <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:rgba(15,42,94,.08)"><i class="fas fa-balance-scale" style="color:#0f2a5e"></i></div>
      <p class="text-gray-400 text-xs font-semibold uppercase tracking-wider">Balans</p>
    </div>
    <p class="text-2xl font-black <%= (stats.income-stats.expense)>=0?'text-green-600':'text-red-500' %>">
      <%= ((stats.income||0)-(stats.expense||0)).toLocaleString() %> <span class="text-sm font-normal text-gray-400">UZS</span>
    </p>
  </div>
</div>

<!-- Quick Actions -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
  <a href="/admin/news/create" class="bg-white rounded-xl p-4 shadow-sm border hover:shadow-md transition flex items-center gap-3">
    <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
      <i class="fas fa-plus text-blue-600"></i>
    </div>
    <div>
      <p class="font-semibold text-gray-800 text-sm">Yangilik</p>
      <p class="text-gray-400 text-xs">Yangi qo'shish</p>
    </div>
  </a>
  <a href="/admin/staff/create" class="bg-white rounded-xl p-4 shadow-sm border hover:shadow-md transition flex items-center gap-3">
    <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center flex-shrink-0">
      <i class="fas fa-user-plus text-green-600"></i>
    </div>
    <div>
      <p class="font-semibold text-gray-800 text-sm">Xodim</p>
      <p class="text-gray-400 text-xs">Yangi qo'shish</p>
    </div>
  </a>
  <a href="/admin/gallery" class="bg-white rounded-xl p-4 shadow-sm border hover:shadow-md transition flex items-center gap-3">
    <div class="w-10 h-10 bg-purple-50 rounded-xl flex items-center justify-center flex-shrink-0">
      <i class="fas fa-image text-purple-600"></i>
    </div>
    <div>
      <p class="font-semibold text-gray-800 text-sm">Galereya</p>
      <p class="text-gray-400 text-xs">Rasm yuklash</p>
    </div>
  </a>
  <a href="/admin/settings" class="bg-white rounded-xl p-4 shadow-sm border hover:shadow-md transition flex items-center gap-3">
    <div class="w-10 h-10 bg-orange-50 rounded-xl flex items-center justify-center flex-shrink-0">
      <i class="fas fa-cog text-orange-500"></i>
    </div>
    <div>
      <p class="font-semibold text-gray-800 text-sm">Sozlamalar</p>
      <p class="text-gray-400 text-xs">Sayt sozlash</p>
    </div>
  </a>
</div>

<!-- Charts + Tables -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
  <div class="bg-white rounded-2xl shadow-sm p-6">
    <h3 class="font-black text-gray-800 mb-4 flex items-center gap-2">
      <i class="fas fa-chart-line text-blue-600"></i> Oylik yangiliklar
    </h3>
    <canvas id="newsChart" height="200"></canvas>
  </div>
  <div class="bg-white rounded-2xl shadow-sm p-6">
    <h3 class="font-black text-gray-800 mb-4 flex items-center gap-2">
      <i class="fas fa-chart-bar text-green-600"></i> Oylik arizalar
    </h3>
    <canvas id="appChart" height="200"></canvas>
  </div>
</div>

<!-- Recent data -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Recent News -->
  <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b flex items-center justify-between">
      <h3 class="font-black text-gray-800">So'nggi yangiliklar</h3>
      <a href="/admin/news" class="text-sm text-blue-600 hover:underline font-medium">Barchasi →</a>
    </div>
    <div class="divide-y">
      <% if(!recentNews || recentNews.length===0){ %>
        <div class="px-6 py-10 text-center text-gray-400">
          <i class="fas fa-newspaper text-3xl mb-2 block text-gray-200"></i>
          Yangiliklar yo'q
        </div>
      <% } %>
      <% recentNews.forEach(n => { %>
        <div class="px-6 py-4 flex items-center gap-3 hover:bg-gray-50 transition">
          <% if(n.image){ %>
            <img src="<%= n.image %>" class="w-12 h-10 rounded-lg object-cover flex-shrink-0">
          <% } else { %>
            <div class="w-12 h-10 bg-gray-100 rounded-lg flex items-center justify-center flex-shrink-0">
              <i class="fas fa-newspaper text-gray-300"></i>
            </div>
          <% } %>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-gray-800 text-sm truncate"><%= n.title_uz %></p>
            <p class="text-gray-400 text-xs mt-0.5"><%= n.createdAt.toLocaleDateString() %></p>
          </div>
          <span class="text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0 <%= n.status==='published'?'bg-green-100 text-green-700':'bg-gray-100 text-gray-500' %>">
            <%= n.status==='published'?'Nashr':'Qoralama' %>
          </span>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- Recent Applications -->
  <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b flex items-center justify-between">
      <h3 class="font-black text-gray-800">So'nggi arizalar</h3>
      <a href="/admin/applications" class="text-sm text-blue-600 hover:underline font-medium">Barchasi →</a>
    </div>
    <div class="divide-y">
      <% if(!recentApps || recentApps.length===0){ %>
        <div class="px-6 py-10 text-center text-gray-400">
          <i class="fas fa-file-alt text-3xl mb-2 block text-gray-200"></i>
          Arizalar yo'q
        </div>
      <% } %>
      <% recentApps.forEach(a => { %>
        <div class="px-6 py-4 flex items-center justify-between hover:bg-gray-50 transition">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-blue-50 flex items-center justify-center text-blue-700 font-bold text-sm flex-shrink-0">
              <%= a.first_name.charAt(0).toUpperCase() %>
            </div>
            <div>
              <p class="font-semibold text-gray-800 text-sm"><%= a.first_name %> <%= a.last_name %></p>
              <p class="text-gray-400 text-xs"><%= a.phone %></p>
            </div>
          </div>
          <span class="text-xs px-2.5 py-1 rounded-full font-medium
            <%= a.status==='accepted'?'bg-green-100 text-green-700':a.status==='rejected'?'bg-red-100 text-red-500':'bg-yellow-100 text-yellow-700' %>">
            <%= a.status==='accepted'?'Qabul':a.status==='rejected'?'Rad':'Kutmoqda' %>
          </span>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<script>
const months = ['Yan','Feb','Mar','Apr','May','Iyn','Iyl','Avg','Sen','Okt','Noy','Dek'];
const newsRaw = <%- JSON.stringify(monthlyNews) %>;
const appRaw = <%- JSON.stringify(monthlyApps) %>;

const newsCounts = Array(12).fill(0);
newsRaw.forEach(d => { newsCounts[d._id.month-1] = d.count; });

const appCounts = Array(12).fill(0);
appRaw.forEach(d => { appCounts[d._id.month-1] = d.count; });

new Chart(document.getElementById('newsChart'), {
  type: 'line',
  data: {
    labels: months,
    datasets: [{
      label: 'Yangiliklar',
      data: newsCounts,
      borderColor: '#2563eb',
      backgroundColor: 'rgba(37,99,235,0.06)',
      tension: 0.4, fill: true,
      pointBackgroundColor: '#2563eb',
      pointRadius: 4
    }]
  },
  options: {
    responsive: true,
    plugins: { legend: { display: false } },
    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } }
  }
});

new Chart(document.getElementById('appChart'), {
  type: 'bar',
  data: {
    labels: months,
    datasets: [{
      label: 'Arizalar',
      data: appCounts,
      backgroundColor: 'rgba(16,185,129,0.8)',
      borderRadius: 8,
      borderSkipped: false
    }]
  },
  options: {
    responsive: true,
    plugins: { legend: { display: false } },
    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } }
  }
});
</script>
