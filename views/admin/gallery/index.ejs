<!-- Upload Form -->
<div class="bg-white rounded-xl shadow-sm p-6 mb-6">
  <h3 class="font-bold text-gray-800 mb-5 flex items-center gap-2">
    <i class="fas fa-plus-circle text-blue-600"></i> Rasm yoki Video qo'shish
  </h3>
  <form method="POST" action="/admin/gallery/upload" enctype="multipart/form-data">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-4">
      <div>
        <label class="block text-xs font-semibold text-gray-600 mb-2">Sarlavha (UZ)</label>
        <input type="text" name="title_uz" placeholder="Rasm/video nomi" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-xs font-semibold text-gray-600 mb-2">Kategoriya</label>
        <input type="text" name="category" value="general" placeholder="sport, tadbirlar..." class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
    </div>
    <!-- Tabs: Rasm vs Video -->
    <div class="flex border-b mb-4">
      <button type="button" onclick="showUploadTab('image')" id="img-tab" class="px-5 py-2 text-sm font-semibold text-blue-600 border-b-2 border-blue-600">
        <i class="fas fa-image mr-1.5"></i> Rasm yuklash
      </button>
      <button type="button" onclick="showUploadTab('video')" id="vid-tab" class="px-5 py-2 text-sm font-medium text-gray-400 hover:text-gray-700">
        <i class="fab fa-youtube mr-1.5"></i> Video URL
      </button>
    </div>
    <div id="upload-image">
      <label class="block border-2 border-dashed border-gray-200 rounded-xl p-6 text-center cursor-pointer hover:border-blue-400 transition">
        <i class="fas fa-cloud-upload-alt text-gray-300 text-4xl mb-2 block"></i>
        <span class="text-sm text-gray-500">Rasm yuklash uchun bosing</span>
        <span class="text-xs text-gray-400 block mt-1">JPG, PNG, WEBP • Max 5MB</span>
        <input type="file" name="image" accept="image/*" class="hidden" onchange="previewGalleryImg(this)">
      </label>
      <img id="gallery-preview" class="hidden mt-3 h-40 mx-auto rounded-xl object-contain">
    </div>
    <div id="upload-video" class="hidden">
      <input type="url" name="video_url" placeholder="https://www.youtube.com/watch?v=... yoki https://youtu.be/..."
        class="w-full border rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      <p class="text-xs text-gray-400 mt-1.5"><i class="fab fa-youtube text-red-500 mr-1"></i>YouTube, Vimeo yoki MP4 havolasi</p>
    </div>
    <button type="submit" class="mt-4 px-6 py-2.5 bg-blue-900 text-white rounded-lg text-sm font-bold hover:bg-blue-800 transition">
      <i class="fas fa-plus mr-1.5"></i> Qo'shish
    </button>
  </form>
</div>

<!-- Filter -->
<div class="flex flex-wrap gap-2 mb-5">
  <a href="/admin/gallery" class="px-3 py-1.5 rounded-lg text-sm font-medium bg-blue-900 text-white">
    Barchasi (<%= gallery.length %>)
  </a>
  <% categories.forEach(cat => { %>
    <a href="/admin/gallery?cat=<%= cat %>" class="px-3 py-1.5 rounded-lg text-sm font-medium bg-white text-gray-600 border hover:bg-gray-50 capitalize"><%= cat %></a>
  <% }) %>
</div>

<!-- Grid -->
<div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3">
  <% if(gallery.length===0){ %>
    <div class="col-span-full py-16 text-center text-gray-400">
      <i class="fas fa-images text-4xl mb-3 block"></i>
      <p>Hozircha rasm yoki video yo'q</p>
    </div>
  <% } %>
  <% gallery.forEach(item => { %>
    <div class="relative group rounded-xl overflow-hidden bg-gray-100 aspect-square">
      <% if(item.type==='video' || item.video_url){ %>
        <div class="w-full h-full bg-gray-800 flex items-center justify-center">
          <i class="fab fa-youtube text-red-500 text-4xl"></i>
        </div>
        <div class="absolute bottom-0 left-0 right-0 bg-black/60 px-2 py-1">
          <p class="text-white text-xs truncate"><%= item.title_uz || 'Video' %></p>
        </div>
      <% } else { %>
        <img src="<%= item.image %>" class="w-full h-full object-cover">
      <% } %>
      <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition flex flex-col items-center justify-center gap-2">
        <span class="text-white text-xs bg-white/10 px-2 py-0.5 rounded capitalize"><%= item.category %></span>
        <form method="POST" action="/admin/gallery/<%= item._id %>/delete" onsubmit="return confirm('O\'chirishni tasdiqlaysizmi?')">
          <button type="submit" class="w-9 h-9 rounded-full bg-red-500 hover:bg-red-600 flex items-center justify-center text-white">
            <i class="fas fa-trash text-xs"></i>
          </button>
        </form>
      </div>
    </div>
  <% }) %>
</div>

<script>
function showUploadTab(tab) {
  document.getElementById('upload-image').classList.toggle('hidden', tab!=='image');
  document.getElementById('upload-video').classList.toggle('hidden', tab!=='video');
  document.getElementById('img-tab').className = tab==='image'
    ? 'px-5 py-2 text-sm font-semibold text-blue-600 border-b-2 border-blue-600'
    : 'px-5 py-2 text-sm font-medium text-gray-400 hover:text-gray-700';
  document.getElementById('vid-tab').className = tab==='video'
    ? 'px-5 py-2 text-sm font-semibold text-blue-600 border-b-2 border-blue-600'
    : 'px-5 py-2 text-sm font-medium text-gray-400 hover:text-gray-700';
}
function previewGalleryImg(input) {
  if(input.files[0]) {
    const r = new FileReader();
    r.onload = e => { const img=document.getElementById('gallery-preview'); img.src=e.target.result; img.classList.remove('hidden'); };
    r.readAsDataURL(input.files[0]);
  }
}
</script>
