<!-- Upload Form -->
<div class="bg-white rounded-xl shadow-sm p-6 mb-6">
  <h3 class="font-bold text-gray-800 mb-4 flex items-center gap-2"><i class="fas fa-upload text-blue-600"></i> Upload Image</h3>
  <form method="POST" action="/admin/gallery/upload" enctype="multipart/form-data">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Image *</label>
        <input type="file" name="image" required accept="image/*" class="w-full border rounded-lg px-3 py-2 text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:bg-blue-50 file:text-blue-700 focus:outline-none">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Category</label>
        <input type="text" name="category" placeholder="e.g. sports, events" value="general" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Title (UZ)</label>
        <input type="text" name="title_uz" placeholder="Rasm sarlavhasi" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div class="flex items-end">
        <button type="submit" class="w-full py-2.5 bg-blue-900 text-white rounded-lg text-sm font-semibold hover:bg-blue-800 transition">
          <i class="fas fa-cloud-upload-alt mr-1.5"></i> Upload
        </button>
      </div>
    </div>
  </form>
</div>

<!-- Filters -->
<div class="flex flex-wrap gap-2 mb-5">
  <a href="/admin/gallery" class="px-3 py-1.5 rounded-lg text-sm font-medium bg-blue-900 text-white">All (<%= gallery.length %>)</a>
  <% categories.forEach(cat => { %>
    <a href="/admin/gallery?cat=<%= cat %>" class="px-3 py-1.5 rounded-lg text-sm font-medium bg-white text-gray-600 border hover:bg-gray-50 capitalize"><%= cat %></a>
  <% }) %>
</div>

<!-- Gallery Grid -->
<div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3">
  <% if (gallery.length === 0) { %>
    <div class="col-span-full py-16 text-center text-gray-400">
      <i class="fas fa-images text-4xl mb-3 block"></i>
      <p>No images uploaded yet</p>
    </div>
  <% } %>
  <% gallery.forEach(img => { %>
    <div class="relative group rounded-xl overflow-hidden bg-gray-100 aspect-square">
      <img src="<%= img.image %>" alt="<%= img.title_uz || '' %>" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition flex flex-col items-center justify-center gap-2">
        <% if (img.category) { %>
          <span class="text-white/80 text-xs bg-white/10 px-2 py-1 rounded"><%= img.category %></span>
        <% } %>
        <form method="POST" action="/admin/gallery/<%= img._id %>/delete" onsubmit="return confirm('Delete this image?')">
          <button type="submit" class="w-9 h-9 rounded-full bg-red-500 hover:bg-red-600 flex items-center justify-center text-white">
            <i class="fas fa-trash text-xs"></i>
          </button>
        </form>
      </div>
    </div>
  <% }) %>
</div>
