<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    <!-- Site Settings -->
    <form method="POST" action="/admin/settings/save" enctype="multipart/form-data">
      <div class="bg-white rounded-xl shadow-sm p-6">
        <h3 class="font-bold text-gray-800 mb-5 flex items-center gap-2"><i class="fas fa-globe text-blue-600"></i> Site Settings</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-5">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Site Name (UZ)</label>
            <input type="text" name="site_name_uz" value="<%= settings.site_name_uz || '' %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Site Name (RU)</label>
            <input type="text" name="site_name_ru" value="<%= settings.site_name_ru || '' %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Site Name (EN)</label>
            <input type="text" name="site_name_en" value="<%= settings.site_name_en || '' %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-5">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Primary Color</label>
            <div class="flex gap-2">
              <input type="color" name="primary_color" value="<%= settings.primary_color || '#1e3a5f' %>" class="h-10 w-16 border rounded-lg cursor-pointer">
              <input type="text" id="primaryHex" value="<%= settings.primary_color || '#1e3a5f' %>" class="flex-1 border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Secondary Color</label>
            <div class="flex gap-2">
              <input type="color" name="secondary_color" value="<%= settings.secondary_color || '#c8a84b' %>" class="h-10 w-16 border rounded-lg cursor-pointer">
              <input type="text" id="secondaryHex" value="<%= settings.secondary_color || '#c8a84b' %>" class="flex-1 border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
          </div>
        </div>

        <!-- Logo -->
        <div class="mb-5">
          <label class="block text-xs font-medium text-gray-600 mb-1.5">Logo</label>
          <div class="flex items-center gap-4">
            <% if (settings.logo) { %><img src="<%= settings.logo %>" class="h-12 w-12 object-contain rounded border"><% } %>
            <input type="file" name="logo" accept="image/*" class="border rounded-lg px-3 py-2 text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:bg-blue-50 file:text-blue-700">
          </div>
        </div>

        <!-- Background -->
        <div class="mb-5">
          <label class="block text-xs font-medium text-gray-600 mb-2">Background Type</label>
          <div class="flex gap-4 mb-3">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="bg_type" value="color" <%= settings.bg_type!=='image'?'checked':'' %> class="text-blue-600">
              <span class="text-sm">Solid Color</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="bg_type" value="image" <%= settings.bg_type==='image'?'checked':'' %> class="text-blue-600">
              <span class="text-sm">Image</span>
            </label>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-gray-500 mb-1">BG Color</label>
              <input type="color" name="bg_color" value="<%= settings.bg_color || '#f8fafc' %>" class="h-10 w-full border rounded-lg cursor-pointer">
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">BG Image</label>
              <input type="file" name="bg_image" accept="image/*" class="border rounded-lg px-2 py-2 text-sm file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:bg-gray-100 file:text-gray-600 w-full">
            </div>
          </div>
        </div>

        <h4 class="font-semibold text-gray-700 mb-3 mt-5">Banner</h4>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Banner Title (UZ)</label>
            <input type="text" name="banner_title_uz" value="<%= settings.banner_title_uz || '' %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Banner Title (RU)</label>
            <input type="text" name="banner_title_ru" value="<%= settings.banner_title_ru || '' %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Banner Title (EN)</label>
            <input type="text" name="banner_title_en" value="<%= settings.banner_title_en || '' %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Subtitle (UZ)</label>
            <input type="text" name="banner_subtitle_uz" value="<%= settings.banner_subtitle_uz || '' %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Subtitle (RU)</label>
            <input type="text" name="banner_subtitle_ru" value="<%= settings.banner_subtitle_ru || '' %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Subtitle (EN)</label>
            <input type="text" name="banner_subtitle_en" value="<%= settings.banner_subtitle_en || '' %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
        </div>
        <div class="mb-5">
          <label class="block text-xs font-medium text-gray-600 mb-1.5">Banner Image</label>
          <div class="flex items-center gap-4">
            <% if (settings.banner_image) { %><img src="<%= settings.banner_image %>" class="h-16 w-24 object-cover rounded-lg border"><% } %>
            <input type="file" name="banner_image" accept="image/*" class="border rounded-lg px-3 py-2 text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:bg-blue-50 file:text-blue-700">
          </div>
        </div>

        <h4 class="font-semibold text-gray-700 mb-3 mt-5">Contact Info</h4>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-5">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Phone</label>
            <input type="text" name="footer_phone" value="<%= settings.footer_phone || '' %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Email</label>
            <input type="text" name="footer_email" value="<%= settings.footer_email || '' %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1.5">Address (UZ)</label>
            <input type="text" name="footer_address_uz" value="<%= settings.footer_address_uz || '' %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
        </div>

        <button type="submit" class="px-6 py-2.5 bg-blue-900 text-white rounded-lg text-sm font-semibold hover:bg-blue-800">
          <i class="fas fa-save mr-1.5"></i> Save Settings
        </button>
      </div>
    </form>
  </div>

  <!-- Right Column -->
  <div class="space-y-6">
    <!-- Stats -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h3 class="font-bold text-gray-800 mb-4 flex items-center gap-2"><i class="fas fa-chart-bar text-blue-600"></i> Site Statistics</h3>
      <form method="POST" action="/admin/settings/stats" class="space-y-3">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1.5">Students Count</label>
          <input type="number" name="students_count" value="<%= stats.students_count || 0 %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1.5">Teachers Count</label>
          <input type="number" name="teachers_count" value="<%= stats.teachers_count || 0 %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1.5">Awards Count</label>
          <input type="number" name="awards_count" value="<%= stats.awards_count || 0 %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1.5">Graduates Count</label>
          <input type="number" name="graduates_count" value="<%= stats.graduates_count || 0 %>" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
        <button type="submit" class="w-full py-2.5 bg-green-600 text-white rounded-lg text-sm font-semibold hover:bg-green-700">
          <i class="fas fa-save mr-1.5"></i> Save Stats
        </button>
      </form>
    </div>

    <!-- Change Password -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h3 class="font-bold text-gray-800 mb-4 flex items-center gap-2"><i class="fas fa-key text-yellow-500"></i> Change Password</h3>
      <form method="POST" action="/admin/settings/password" class="space-y-3">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1.5">Current Password</label>
          <input type="password" name="current_password" required class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1.5">New Password</label>
          <input type="password" name="new_password" required minlength="6" class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
        <button type="submit" class="w-full py-2.5 bg-yellow-500 text-white rounded-lg text-sm font-semibold hover:bg-yellow-600">
          <i class="fas fa-key mr-1.5"></i> Change Password
        </button>
      </form>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('input[type=color]').forEach(c => {
  c.addEventListener('input', () => {
    const hex = document.getElementById(c.name === 'primary_color' ? 'primaryHex' : 'secondaryHex');
    if (hex) hex.value = c.value;
  });
});
</script>
