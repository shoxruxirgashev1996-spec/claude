<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Admin Panel</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    :root {
      --primary: <%= settings.primary_color || '#1e3a5f' %>;
      --secondary: <%= settings.secondary_color || '#c8a84b' %>;
    }
    .sidebar { background: var(--primary); }
    .nav-link.active, .nav-link:hover { background: rgba(255,255,255,0.15); }
    .btn-primary { background: var(--primary); }
    .btn-primary:hover { opacity: 0.9; }
    .badge-secondary { background: var(--secondary); }
    * { transition: background-color 0.15s; }
    .sidebar-link { @apply flex items-center gap-3 px-4 py-2.5 text-white/80 hover:text-white rounded-lg hover:bg-white/10 text-sm font-medium; }
  </style>
</head>
<body class="bg-gray-50 min-h-screen flex">
  <!-- Sidebar -->
  <aside class="sidebar w-64 min-h-screen flex flex-col fixed left-0 top-0 z-40 shadow-xl">
    <div class="p-5 border-b border-white/10">
      <% if (settings.logo) { %>
        <img src="<%= settings.logo %>" alt="Logo" class="h-10 mb-2">
      <% } %>
      <h1 class="text-white font-bold text-lg leading-tight">
        <%= settings.site_name_uz || 'Maktab CMS' %>
      </h1>
      <p class="text-white/50 text-xs mt-0.5">Admin Panel</p>
    </div>
    <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
      <a href="/admin/dashboard" class="sidebar-link <%= title==='Dashboard'?'bg-white/20 text-white':'' %>">
        <i class="fas fa-tachometer-alt w-5"></i> Dashboard
      </a>
      <div class="pt-2 pb-1 px-4 text-white/30 text-xs uppercase font-semibold tracking-wider">Content</div>
      <a href="/admin/news" class="sidebar-link <%= title.includes('News')?'bg-white/20 text-white':'' %>">
        <i class="fas fa-newspaper w-5"></i> News
      </a>
      <a href="/admin/announcements" class="sidebar-link <%= title.includes('Announcement')?'bg-white/20 text-white':'' %>">
        <i class="fas fa-bullhorn w-5"></i> Announcements
      </a>
      <a href="/admin/gallery" class="sidebar-link <%= title.includes('Gallery')?'bg-white/20 text-white':'' %>">
        <i class="fas fa-images w-5"></i> Gallery
      </a>
      <a href="/admin/about" class="sidebar-link <%= title.includes('About')?'bg-white/20 text-white':'' %>">
        <i class="fas fa-info-circle w-5"></i> About Page
      </a>
      <div class="pt-2 pb-1 px-4 text-white/30 text-xs uppercase font-semibold tracking-wider">Management</div>
      <a href="/admin/applications" class="sidebar-link <%= title.includes('Application')?'bg-white/20 text-white':'' %>">
        <i class="fas fa-file-alt w-5"></i> Applications
      </a>
      <a href="/admin/contacts" class="sidebar-link <%= title.includes('Messages')?'bg-white/20 text-white':'' %>">
        <i class="fas fa-envelope w-5"></i> Messages
      </a>
      <a href="/admin/budget" class="sidebar-link <%= title.includes('Budget')?'bg-white/20 text-white':'' %>">
        <i class="fas fa-chart-bar w-5"></i> Budget
      </a>
      <div class="pt-2 pb-1 px-4 text-white/30 text-xs uppercase font-semibold tracking-wider">System</div>
      <a href="/admin/settings" class="sidebar-link <%= title.includes('Settings')?'bg-white/20 text-white':'' %>">
        <i class="fas fa-cog w-5"></i> Settings
      </a>
      <% if (currentUser && currentUser.role === 'superadmin') { %>
      <a href="/admin/users" class="sidebar-link <%= title.includes('User')?'bg-white/20 text-white':'' %>">
        <i class="fas fa-users w-5"></i> Users
      </a>
      <% } %>
    </nav>
    <div class="p-4 border-t border-white/10">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-white/20 flex items-center justify-center text-white font-bold text-sm">
          <%= currentUser?.name?.charAt(0)?.toUpperCase() %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-white text-sm font-medium truncate"><%= currentUser?.name %></p>
          <p class="text-white/50 text-xs capitalize"><%= currentUser?.role %></p>
        </div>
        <a href="/admin/logout" class="text-white/50 hover:text-white text-sm" title="Logout">
          <i class="fas fa-sign-out-alt"></i>
        </a>
      </div>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="ml-64 flex-1 flex flex-col min-h-screen">
    <!-- Topbar -->
    <header class="bg-white shadow-sm sticky top-0 z-30 px-6 py-4 flex items-center justify-between">
      <div>
        <h2 class="font-bold text-gray-800 text-xl"><%= title %></h2>
      </div>
      <div class="flex items-center gap-4">
        <a href="/" target="_blank" class="text-gray-500 hover:text-gray-800 text-sm flex items-center gap-1">
          <i class="fas fa-external-link-alt"></i> View Site
        </a>
      </div>
    </header>

    <div class="flex-1 p-6">
      <!-- Flash Messages -->
      <% if (messages.error && messages.error.length) { %>
        <div class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg flex items-center gap-2">
          <i class="fas fa-exclamation-circle"></i> <%= messages.error[0] %>
        </div>
      <% } %>
      <% if (messages.success && messages.success.length) { %>
        <div class="mb-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg flex items-center gap-2">
          <i class="fas fa-check-circle"></i> <%= messages.success[0] %>
        </div>
      <% } %>

      <%- body %>
    </div>
  </main>
</body>
</html>
