<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Admin Panel</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    :root { --primary: <%= settings.primary_color || '#1e3a5f' %>; --secondary: <%= settings.secondary_color || '#c8a84b' %>; }
    .sidebar { background: var(--primary); }
    .sidebar-link { display:flex; align-items:center; gap:10px; padding:9px 14px; color:rgba(255,255,255,.75); border-radius:8px; font-size:13.5px; font-weight:500; transition:all .15s; text-decoration:none; }
    .sidebar-link:hover, .sidebar-link.active { background:rgba(255,255,255,.15); color:#fff; }
    .sidebar-section { padding:16px 14px 4px; font-size:10px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:rgba(255,255,255,.3); }
  </style>
</head>
<body class="bg-gray-50 min-h-screen flex">

  <!-- Sidebar -->
  <aside class="sidebar w-60 min-h-screen flex flex-col fixed left-0 top-0 z-40 shadow-xl">
    <div class="p-5 border-b border-white/10">
      <% if(settings.logo){ %>
        <img src="<%= settings.logo %>" alt="Logo" class="h-9 mb-2 brightness-0 invert opacity-90">
      <% } %>
      <h1 class="text-white font-bold text-base leading-tight"><%= settings.site_name_uz || 'Maktab CMS' %></h1>
      <p class="text-white/40 text-xs mt-0.5">Admin boshqaruv paneli</p>
    </div>

    <nav class="flex-1 p-3 overflow-y-auto space-y-0.5">
      <a href="/admin/dashboard" class="sidebar-link <%= title==='Dashboard'?'active':'' %>">
        <i class="fas fa-tachometer-alt w-4 text-center"></i> Dashboard
      </a>

      <div class="sidebar-section">Kontent</div>
      <a href="/admin/news" class="sidebar-link <%= title.includes('News')?'active':'' %>">
        <i class="fas fa-newspaper w-4 text-center"></i> Yangiliklar
      </a>
      <a href="/admin/announcements" class="sidebar-link <%= title.includes('Announcement')?'active':'' %>">
        <i class="fas fa-bullhorn w-4 text-center"></i> E'lonlar
      </a>
      <a href="/admin/gallery" class="sidebar-link <%= title.includes('Gallery')?'active':'' %>">
        <i class="fas fa-images w-4 text-center"></i> Galereya
      </a>

      <div class="sidebar-section">Maktab</div>
      <a href="/admin/staff" class="sidebar-link <%= title.includes('odim')?'active':'' %>">
        <i class="fas fa-users w-4 text-center"></i> Xodimlar
      </a>
      <a href="/admin/about" class="sidebar-link <%= title.includes('About')?'active':'' %>">
        <i class="fas fa-info-circle w-4 text-center"></i> Maktab haqida
      </a>

      <div class="sidebar-section">Boshqaruv</div>
      <a href="/admin/applications" class="sidebar-link <%= title.includes('Application')?'active':'' %>">
        <i class="fas fa-file-alt w-4 text-center"></i> Arizalar
      </a>
      <a href="/admin/contacts" class="sidebar-link <%= title.includes('Messages')?'active':'' %>">
        <i class="fas fa-envelope w-4 text-center"></i> Xabarlar
      </a>
      <a href="/admin/budget" class="sidebar-link <%= title.includes('Budget')?'active':'' %>">
        <i class="fas fa-chart-bar w-4 text-center"></i> Budjet
      </a>

      <div class="sidebar-section">Tizim</div>
      <a href="/admin/settings" class="sidebar-link <%= title.includes('Settings')?'active':'' %>">
        <i class="fas fa-cog w-4 text-center"></i> Sozlamalar
      </a>
      <% if(currentUser && currentUser.role==='superadmin'){ %>
      <a href="/admin/users" class="sidebar-link <%= title.includes('User')?'active':'' %>">
        <i class="fas fa-user-shield w-4 text-center"></i> Foydalanuvchilar
      </a>
      <% } %>
    </nav>

    <div class="p-4 border-t border-white/10">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-white/20 flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
          <%= currentUser?.name?.charAt(0)?.toUpperCase() %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-white text-sm font-medium truncate"><%= currentUser?.name %></p>
          <p class="text-white/40 text-xs capitalize"><%= currentUser?.role %></p>
        </div>
        <a href="/admin/logout" class="text-white/40 hover:text-white" title="Chiqish">
          <i class="fas fa-sign-out-alt"></i>
        </a>
      </div>
    </div>
  </aside>

  <!-- Main -->
  <main class="ml-60 flex-1 flex flex-col min-h-screen">
    <header class="bg-white shadow-sm sticky top-0 z-30 px-6 py-4 flex items-center justify-between">
      <h2 class="font-bold text-gray-800 text-xl"><%= title %></h2>
      <div class="flex items-center gap-3">
        <a href="/" target="_blank" class="text-gray-400 hover:text-gray-700 text-sm flex items-center gap-1.5">
          <i class="fas fa-external-link-alt text-xs"></i> Saytni ko'rish
        </a>
      </div>
    </header>

    <div class="flex-1 p-6">
      <% if(messages.error && messages.error.length){ %>
        <div class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl flex items-center gap-2 text-sm">
          <i class="fas fa-exclamation-circle"></i> <%= messages.error[0] %>
        </div>
      <% } %>
      <% if(messages.success && messages.success.length){ %>
        <div class="mb-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl flex items-center gap-2 text-sm">
          <i class="fas fa-check-circle"></i> <%= messages.success[0] %>
        </div>
      <% } %>
      <%- body %>
    </div>
  </main>

</body>
</html>
