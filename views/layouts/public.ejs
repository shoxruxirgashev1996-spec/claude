<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | <%= settings['site_name_' + lang] || settings.site_name_uz || 'Maktab' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: <%= settings.primary_color || '#1a3a6e' %>;
      --secondary: <%= settings.secondary_color || '#e8a020' %>;
    }
    * { font-family: 'Inter', sans-serif; box-sizing: border-box; }
    body { margin: 0; padding: 0; }
    .bg-primary { background-color: var(--primary) !important; }
    .text-primary { color: var(--primary) !important; }
    .border-primary { border-color: var(--primary) !important; }
    .bg-secondary { background-color: var(--secondary) !important; }
    .text-secondary { color: var(--secondary) !important; }
    .btn-primary { background-color: var(--primary); color: #fff; border: none; cursor: pointer; transition: opacity .2s; }
    .btn-primary:hover { opacity: .88; }
    .btn-secondary { background-color: var(--secondary); color: #fff; border: none; cursor: pointer; transition: opacity .2s; }
    .btn-secondary:hover { opacity: .88; }
    /* Top bar */
    .top-bar { background: var(--primary); }
    /* Navigation */
    .main-nav { background: #fff; box-shadow: 0 2px 12px rgba(0,0,0,.08); }
    .nav-link { position: relative; color: #2d3748; font-weight: 500; font-size: 14px; transition: color .2s; }
    .nav-link:hover { color: var(--primary); }
    .nav-link::after { content:''; position:absolute; bottom:-4px; left:0; width:0; height:2px; background:var(--secondary); transition:width .3s; }
    .nav-link:hover::after, .nav-link.active::after { width:100%; }
    /* Card */
    .card-hover { transition: transform .25s, box-shadow .25s; }
    .card-hover:hover { transform: translateY(-5px); box-shadow: 0 16px 40px rgba(0,0,0,.12); }
    /* Section */
    .section-title { font-size: 2rem; font-weight: 800; color: #1a202c; }
    .section-subtitle { font-size: .85rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--secondary); margin-bottom: .4rem; }
    /* Announcement ticker */
    @keyframes ticker { 0% { transform:translateX(100%); } 100% { transform:translateX(-100%); } }
    .ticker-inner { white-space: nowrap; animation: ticker 30s linear infinite; display: inline-block; }
    /* Dropdown */
    .dropdown:hover .dropdown-menu { display: block; }
    .dropdown-menu { display: none; position: absolute; top: 100%; left: 0; background: #fff; box-shadow: 0 8px 24px rgba(0,0,0,.12); border-radius: 8px; min-width: 220px; z-index: 100; padding: 8px 0; }
    .dropdown-menu a { display: block; padding: 8px 16px; font-size: 13px; color: #374151; transition: background .15s; }
    .dropdown-menu a:hover { background: #f3f4f6; color: var(--primary); }
    /* Mobile menu */
    #mobile-menu { display: none; }
    #mobile-menu.open { display: block; }
    /* Lang switcher */
    .lang-btn { padding: 3px 10px; border-radius: 4px; font-size: 12px; font-weight: 700; transition: all .2s; cursor: pointer; border: none; }
    .lang-btn.active { background: var(--secondary); color: #fff; }
    .lang-btn:not(.active) { background: transparent; color: rgba(255,255,255,.7); }
    .lang-btn:not(.active):hover { color: #fff; }
  </style>
</head>
<body class="bg-gray-50">

<!-- ── Top Info Bar ── -->
<div class="top-bar py-2 hidden md:block">
  <div class="max-w-7xl mx-auto px-4 flex items-center justify-between">
    <div class="flex items-center gap-6 text-white/80 text-xs">
      <% if(settings.footer_phone){ %>
        <span><i class="fas fa-phone mr-1.5"></i><%= settings.footer_phone %></span>
      <% } %>
      <% if(settings.footer_email){ %>
        <span><i class="fas fa-envelope mr-1.5"></i><%= settings.footer_email %></span>
      <% } %>
      <% if(settings.footer_address_uz){ %>
        <span class="hidden lg:inline"><i class="fas fa-map-marker-alt mr-1.5"></i><%= settings.footer_address_uz %></span>
      <% } %>
    </div>
    <div class="flex items-center gap-1">
      <a href="?lang=uz" class="lang-btn <%= lang==='uz'?'active':'' %>">UZ</a>
      <a href="?lang=ru" class="lang-btn <%= lang==='ru'?'active':'' %>">RU</a>
      <a href="?lang=en" class="lang-btn <%= lang==='en'?'active':'' %>">EN</a>
    </div>
  </div>
</div>

<!-- ── Main Navigation ── -->
<nav class="main-nav sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 flex-shrink-0">
        <% if(settings.logo){ %>
          <img src="<%= settings.logo %>" alt="Logo" class="h-12 w-12 object-contain">
        <% } else { %>
          <div class="w-12 h-12 rounded-lg flex items-center justify-center text-white font-bold text-xl" style="background:var(--primary)">M</div>
        <% } %>
        <div class="hidden sm:block">
          <p class="font-bold text-gray-900 text-sm leading-tight"><%= settings['site_name_' + lang] || settings.site_name_uz || 'Maktab' %></p>
          <p class="text-gray-400 text-xs">Rasmiy veb-sayt</p>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        <a href="/" class="nav-link px-3 py-2 rounded-lg hover:bg-gray-50 <%= title==='Home'?'active':'' %>">
          <% if(lang==='uz'){%>Bosh sahifa<%}else if(lang==='ru'){%>Главная<%}else{%>Home<%}%>
        </a>
        <a href="/about" class="nav-link px-3 py-2 rounded-lg hover:bg-gray-50">
          <% if(lang==='uz'){%>Universitet haqida<%}else if(lang==='ru'){%>О вузе<%}else{%>About<%}%>
        </a>
        <a href="/news" class="nav-link px-3 py-2 rounded-lg hover:bg-gray-50">
          <% if(lang==='uz'){%>Yangiliklar<%}else if(lang==='ru'){%>Новости<%}else{%>News<%}%>
        </a>
        <a href="/admission" class="nav-link px-3 py-2 rounded-lg hover:bg-gray-50">
          <% if(lang==='uz'){%>Qabul<%}else if(lang==='ru'){%>Приём<%}else{%>Admission<%}%>
        </a>
        <a href="/gallery" class="nav-link px-3 py-2 rounded-lg hover:bg-gray-50">
          <% if(lang==='uz'){%>Galereya<%}else if(lang==='ru'){%>Галерея<%}else{%>Gallery<%}%>
        </a>
        <a href="/budget" class="nav-link px-3 py-2 rounded-lg hover:bg-gray-50">
          <% if(lang==='uz'){%>Moliyaviy faoliyat<%}else if(lang==='ru'){%>Финансы<%}else{%>Finance<%}%>
        </a>
        <a href="/contact" class="nav-link px-3 py-2 rounded-lg hover:bg-gray-50">
          <% if(lang==='uz'){%>Aloqa<%}else if(lang==='ru'){%>Контакт<%}else{%>Contact<%}%>
        </a>
      </div>

      <!-- Right -->
      <div class="flex items-center gap-3">
        <!-- Mobile lang -->
        <div class="flex lg:hidden gap-1">
          <a href="?lang=uz" class="text-xs font-bold px-2 py-1 rounded <%= lang==='uz'?'bg-blue-900 text-white':'text-gray-500' %>">UZ</a>
          <a href="?lang=ru" class="text-xs font-bold px-2 py-1 rounded <%= lang==='ru'?'bg-blue-900 text-white':'text-gray-500' %>">RU</a>
          <a href="?lang=en" class="text-xs font-bold px-2 py-1 rounded <%= lang==='en'?'bg-blue-900 text-white':'text-gray-500' %>">EN</a>
        </div>
        <!-- Apply btn -->
        <a href="/admission" class="hidden md:inline-flex items-center gap-2 px-4 py-2 rounded-lg text-white text-sm font-semibold btn-secondary">
          <i class="fas fa-pen-to-square text-xs"></i>
          <% if(lang==='uz'){%>Ariza topshirish<%}else if(lang==='ru'){%>Подать заявку<%}else{%>Apply Now<%}%>
        </a>
        <!-- Burger -->
        <button onclick="document.getElementById('mobile-menu').classList.toggle('open')" class="lg:hidden p-2 rounded-lg hover:bg-gray-100">
          <i class="fas fa-bars text-gray-700"></i>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="border-t pb-4 pt-2">
      <% const navLinks = lang==='uz'
        ? [['/', 'Bosh sahifa'], ['/about', 'Universitet haqida'], ['/news', 'Yangiliklar'], ['/admission', 'Qabul'], ['/gallery', 'Galereya'], ['/budget', 'Moliyaviy faoliyat'], ['/contact', 'Aloqa']]
        : lang==='ru'
        ? [['/', 'Главная'], ['/about', 'О вузе'], ['/news', 'Новости'], ['/admission', 'Приём'], ['/gallery', 'Галерея'], ['/budget', 'Финансы'], ['/contact', 'Контакт']]
        : [['/', 'Home'], ['/about', 'About'], ['/news', 'News'], ['/admission', 'Admission'], ['/gallery', 'Gallery'], ['/budget', 'Finance'], ['/contact', 'Contact']]
      %>
      <% navLinks.forEach(([href, label]) => { %>
        <a href="<%= href %>" class="block px-4 py-2.5 text-gray-700 hover:bg-gray-50 rounded-lg text-sm font-medium"><%= label %></a>
      <% }) %>
    </div>
  </div>
</nav>

<!-- Flash Messages -->
<% if (messages.error && messages.error.length) { %>
  <div class="bg-red-50 border-b border-red-100 px-4 py-3 text-red-700 text-center text-sm">
    <i class="fas fa-exclamation-circle mr-1"></i> <%= messages.error[0] %>
  </div>
<% } %>
<% if (messages.success && messages.success.length) { %>
  <div class="bg-green-50 border-b border-green-100 px-4 py-3 text-green-700 text-center text-sm">
    <i class="fas fa-check-circle mr-1"></i> <%= messages.success[0] %>
  </div>
<% } %>

<%- body %>

<!-- ── Footer ── -->
<footer style="background:var(--primary);" class="text-white mt-16">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <div class="md:col-span-1">
        <% if(settings.logo){ %>
          <img src="<%= settings.logo %>" alt="Logo" class="h-14 mb-3 brightness-0 invert">
        <% } %>
        <h3 class="font-bold text-lg mb-2"><%= settings['site_name_' + lang] || settings.site_name_uz || 'Maktab' %></h3>
        <p class="text-white/60 text-sm leading-relaxed">
          <% if(lang==='uz'){%>Bilimli avlod – kelajak poydevori<%}else if(lang==='ru'){%>Знающее поколение — основа будущего<%}else{%>Educated generation — foundation of the future<%}%>
        </p>
        <div class="flex gap-3 mt-4">
          <a href="#" class="w-8 h-8 rounded-lg bg-white/10 hover:bg-white/20 flex items-center justify-center"><i class="fab fa-telegram text-sm"></i></a>
          <a href="#" class="w-8 h-8 rounded-lg bg-white/10 hover:bg-white/20 flex items-center justify-center"><i class="fab fa-instagram text-sm"></i></a>
          <a href="#" class="w-8 h-8 rounded-lg bg-white/10 hover:bg-white/20 flex items-center justify-center"><i class="fab fa-facebook text-sm"></i></a>
          <a href="#" class="w-8 h-8 rounded-lg bg-white/10 hover:bg-white/20 flex items-center justify-center"><i class="fab fa-youtube text-sm"></i></a>
        </div>
      </div>
      <div>
        <h4 class="font-semibold mb-3 text-white/90"><% if(lang==='uz'){%>Sahifalar<%}else if(lang==='ru'){%>Страницы<%}else{%>Pages<%}%></h4>
        <ul class="space-y-2 text-sm text-white/60">
          <li><a href="/" class="hover:text-white transition"><% if(lang==='uz'){%>Bosh sahifa<%}else if(lang==='ru'){%>Главная<%}else{%>Home<%}%></a></li>
          <li><a href="/about" class="hover:text-white transition"><% if(lang==='uz'){%>Universitet haqida<%}else if(lang==='ru'){%>О вузе<%}else{%>About<%}%></a></li>
          <li><a href="/news" class="hover:text-white transition"><% if(lang==='uz'){%>Yangiliklar<%}else if(lang==='ru'){%>Новости<%}else{%>News<%}%></a></li>
          <li><a href="/gallery" class="hover:text-white transition"><% if(lang==='uz'){%>Galereya<%}else if(lang==='ru'){%>Галерея<%}else{%>Gallery<%}%></a></li>
          <li><a href="/budget" class="hover:text-white transition"><% if(lang==='uz'){%>Moliyaviy faoliyat<%}else if(lang==='ru'){%>Финансы<%}else{%>Finance<%}%></a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-semibold mb-3 text-white/90"><% if(lang==='uz'){%>Talabalarga<%}else if(lang==='ru'){%>Студентам<%}else{%>Students<%}%></h4>
        <ul class="space-y-2 text-sm text-white/60">
          <li><a href="/admission" class="hover:text-white transition"><% if(lang==='uz'){%>Qabul<%}else if(lang==='ru'){%>Приём<%}else{%>Admission<%}%></a></li>
          <li><a href="/contact" class="hover:text-white transition"><% if(lang==='uz'){%>Aloqa<%}else if(lang==='ru'){%>Контакт<%}else{%>Contact<%}%></a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-semibold mb-3 text-white/90"><% if(lang==='uz'){%>Aloqa<%}else if(lang==='ru'){%>Контакт<%}else{%>Contact<%}%></h4>
        <ul class="space-y-3 text-sm text-white/60">
          <% if(settings.footer_phone){ %><li class="flex items-start gap-2"><i class="fas fa-phone mt-0.5 flex-shrink-0"></i><%= settings.footer_phone %></li><% } %>
          <% if(settings.footer_email){ %><li class="flex items-start gap-2"><i class="fas fa-envelope mt-0.5 flex-shrink-0"></i><%= settings.footer_email %></li><% } %>
          <% if(settings.footer_address_uz){ %><li class="flex items-start gap-2"><i class="fas fa-map-marker-alt mt-0.5 flex-shrink-0"></i><%= settings.footer_address_uz %></li><% } %>
        </ul>
      </div>
    </div>
    <div class="border-t border-white/10 pt-6 text-center text-white/40 text-xs">
      &copy; <%= new Date().getFullYear() %> <%= settings['site_name_' + lang] || settings.site_name_uz || 'Maktab' %>. Barcha huquqlar himoyalangan.
    </div>
  </div>
</footer>

</body>
</html>
