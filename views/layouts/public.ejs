<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | <%= settings.site_name_uz || 'Presidential School' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: <%= settings.primary_color || '#1e3a5f' %>;
      --secondary: <%= settings.secondary_color || '#c8a84b' %>;
    }
    body { font-family: 'Source Sans 3', sans-serif; }
    h1, h2, h3 { font-family: 'Playfair Display', serif; }
    .bg-primary { background-color: var(--primary); }
    .text-primary { color: var(--primary); }
    .border-primary { border-color: var(--primary); }
    .bg-secondary { background-color: var(--secondary); }
    .text-secondary { color: var(--secondary); }
    .nav-link { position: relative; }
    .nav-link::after { content:''; position:absolute; bottom:-2px; left:0; width:0; height:2px; background:var(--secondary); transition:width 0.3s; }
    .nav-link:hover::after { width:100%; }
    .hero-section {
      <% if (settings.bg_type === 'image' && settings.bg_image) { %>
        background: linear-gradient(rgba(30,58,95,0.85), rgba(30,58,95,0.7)), url('<%= settings.bg_image %>') center/cover no-repeat;
      <% } else { %>
        background: linear-gradient(135deg, var(--primary) 0%, #2a5298 60%, #1a237e 100%);
      <% } %>
    }
    .card-hover { transition: transform 0.2s, box-shadow 0.2s; }
    .card-hover:hover { transform: translateY(-4px); box-shadow: 0 20px 40px rgba(0,0,0,0.12); }
    .announcement-bar { background: var(--secondary); }
    .btn-primary { background: var(--primary); color: white; }
    .btn-primary:hover { opacity: 0.9; }
    .btn-secondary { background: var(--secondary); color: white; }
    .btn-secondary:hover { opacity: 0.9; }
  </style>
</head>
<body class="<% if(settings.bg_type==='color' && settings.bg_color){%><%='' %><% } %>">

  <!-- Announcement Bar -->
  <% const activeAnnouncements = []; /* handled in template */ %>

  <!-- Navigation -->
  <nav class="bg-primary shadow-lg sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-3">
          <% if (settings.logo) { %>
            <img src="<%= settings.logo %>" alt="Logo" class="h-10 w-10 rounded object-cover">
          <% } else { %>
            <div class="w-10 h-10 bg-white/20 rounded flex items-center justify-center text-white font-bold">P</div>
          <% } %>
          <div>
            <p class="text-white font-bold text-sm leading-tight"><%= settings[`site_name_${lang}`] || settings.site_name_uz || 'Presidential School' %></p>
            <p class="text-white/60 text-xs">Official Website</p>
          </div>
        </a>
        <div class="hidden md:flex items-center gap-6">
          <a href="/" class="nav-link text-white/80 hover:text-white text-sm font-medium">
            <% if(lang==='uz'){%>Bosh sahifa<%}else if(lang==='ru'){%>Главная<%}else{%>Home<%}%>
          </a>
          <a href="/about" class="nav-link text-white/80 hover:text-white text-sm font-medium">
            <% if(lang==='uz'){%>Maktab haqida<%}else if(lang==='ru'){%>О школе<%}else{%>About<%}%>
          </a>
          <a href="/admission" class="nav-link text-white/80 hover:text-white text-sm font-medium">
            <% if(lang==='uz'){%>Qabul<%}else if(lang==='ru'){%>Приём<%}else{%>Admission<%}%>
          </a>
          <a href="/news" class="nav-link text-white/80 hover:text-white text-sm font-medium">
            <% if(lang==='uz'){%>Yangiliklar<%}else if(lang==='ru'){%>Новости<%}else{%>News<%}%>
          </a>
          <a href="/gallery" class="nav-link text-white/80 hover:text-white text-sm font-medium">
            <% if(lang==='uz'){%>Galereya<%}else if(lang==='ru'){%>Галерея<%}else{%>Gallery<%}%>
          </a>
          <a href="/budget" class="nav-link text-white/80 hover:text-white text-sm font-medium">
            <% if(lang==='uz'){%>Budjet<%}else if(lang==='ru'){%>Бюджет<%}else{%>Budget<%}%>
          </a>
          <a href="/contact" class="nav-link text-white/80 hover:text-white text-sm font-medium">
            <% if(lang==='uz'){%>Aloqa<%}else if(lang==='ru'){%>Контакт<%}else{%>Contact<%}%>
          </a>
        </div>
        <div class="flex items-center gap-3">
          <!-- Language Switcher -->
          <div class="flex gap-1">
            <a href="?lang=uz" class="px-2 py-1 rounded text-xs font-semibold <%= lang==='uz'?'bg-white text-primary':'text-white/70 hover:text-white' %>">UZ</a>
            <a href="?lang=ru" class="px-2 py-1 rounded text-xs font-semibold <%= lang==='ru'?'bg-white text-primary':'text-white/70 hover:text-white' %>">RU</a>
            <a href="?lang=en" class="px-2 py-1 rounded text-xs font-semibold <%= lang==='en'?'bg-white text-primary':'text-white/70 hover:text-white' %>">EN</a>
          </div>
          <a href="/admission" class="hidden md:inline-flex items-center gap-1.5 px-4 py-2 bg-secondary text-white rounded-lg text-sm font-semibold hover:opacity-90 transition">
            <i class="fas fa-pen-to-square text-xs"></i>
            <% if(lang==='uz'){%>Ariza topshirish<%}else if(lang==='ru'){%>Подать заявку<%}else{%>Apply Now<%}%>
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Flash Messages -->
  <% if (messages.error && messages.error.length) { %>
    <div class="bg-red-50 border-b border-red-200 px-4 py-3 text-red-700 text-center text-sm">
      <i class="fas fa-exclamation-circle mr-1"></i> <%= messages.error[0] %>
    </div>
  <% } %>
  <% if (messages.success && messages.success.length) { %>
    <div class="bg-green-50 border-b border-green-200 px-4 py-3 text-green-700 text-center text-sm">
      <i class="fas fa-check-circle mr-1"></i> <%= messages.success[0] %>
    </div>
  <% } %>

  <%- body %>

  <!-- Footer -->
  <footer class="bg-primary text-white mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="col-span-1 md:col-span-2">
          <% if (settings.logo) { %>
            <img src="<%= settings.logo %>" alt="Logo" class="h-12 mb-3">
          <% } %>
          <h3 class="text-xl font-bold mb-2"><%= settings[`site_name_${lang}`] || 'Presidential School' %></h3>
          <p class="text-white/60 text-sm leading-relaxed">
            <% if(lang==='uz'){%>Bilimli avlod – kelajak poydevori<%}else if(lang==='ru'){%>Знающее поколение — основа будущего<%}else{%>Educated generation — foundation of the future<%}%>
          </p>
        </div>
        <div>
          <h4 class="font-semibold mb-3 text-secondary"><% if(lang==='uz'){%>Sahifalar<%}else if(lang==='ru'){%>Страницы<%}else{%>Pages<%}%></h4>
          <ul class="space-y-2 text-sm text-white/70">
            <li><a href="/" class="hover:text-white"><% if(lang==='uz'){%>Bosh sahifa<%}else if(lang==='ru'){%>Главная<%}else{%>Home<%}%></a></li>
            <li><a href="/about" class="hover:text-white"><% if(lang==='uz'){%>Maktab haqida<%}else if(lang==='ru'){%>О школе<%}else{%>About<%}%></a></li>
            <li><a href="/news" class="hover:text-white"><% if(lang==='uz'){%>Yangiliklar<%}else if(lang==='ru'){%>Новости<%}else{%>News<%}%></a></li>
            <li><a href="/gallery" class="hover:text-white"><% if(lang==='uz'){%>Galereya<%}else if(lang==='ru'){%>Галерея<%}else{%>Gallery<%}%></a></li>
            <li><a href="/budget" class="hover:text-white"><% if(lang==='uz'){%>Budjet<%}else if(lang==='ru'){%>Бюджет<%}else{%>Budget<%}%></a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold mb-3 text-secondary"><% if(lang==='uz'){%>Aloqa<%}else if(lang==='ru'){%>Контакт<%}else{%>Contact<%}%></h4>
          <ul class="space-y-2 text-sm text-white/70">
            <% if(settings.footer_phone){ %><li><i class="fas fa-phone mr-2"></i><%= settings.footer_phone %></li><% } %>
            <% if(settings.footer_email){ %><li><i class="fas fa-envelope mr-2"></i><%= settings.footer_email %></li><% } %>
            <% if(settings.footer_address_uz){ %><li><i class="fas fa-map-marker-alt mr-2"></i><%= settings.footer_address_uz %></li><% } %>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/10 mt-8 pt-6 text-center text-white/40 text-xs">
        &copy; <%= new Date().getFullYear() %> <%= settings[`site_name_${lang}`] || 'Presidential School' %>. All rights reserved.
      </div>
    </div>
  </footer>
</body>
</html>
