<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | <%= settings['site_name_' + lang] || settings.site_name_uz || 'Maktab' %></title>
  <% if(settings.favicon_url){ %><link rel="icon" href="<%= settings.favicon_url %>"><% } %>
  <meta name="description" content="<%= settings['meta_desc_' + lang] || settings.meta_desc_uz || '' %>">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Merriweather:wght@700;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: <%= settings.primary_color || '#0f2a5e' %>;
      --primary-light: <%= settings.primary_color ? settings.primary_color + '18' : '#0f2a5e18' %>;
      --secondary: <%= settings.secondary_color || '#d4a017' %>;
      --secondary-light: <%= settings.secondary_color ? settings.secondary_color + '22' : '#d4a01722' %>;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; color: #1a202c; background: #f8f9fc; line-height: 1.6; }
    h1, h2, h3 { font-family: 'Merriweather', serif; }

    /* Colors */
    .bg-primary { background: var(--primary) !important; }
    .text-primary { color: var(--primary) !important; }
    .text-secondary { color: var(--secondary) !important; }
    .bg-secondary { background: var(--secondary) !important; }
    .border-primary { border-color: var(--primary) !important; }
    .border-secondary { border-color: var(--secondary) !important; }

    /* Buttons */
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 12px 28px; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: all .25s; border: none; text-decoration: none; font-family: 'Inter', sans-serif; }
    .btn-primary { background: var(--primary); color: #fff; }
    .btn-primary:hover { opacity: .88; transform: translateY(-1px); box-shadow: 0 8px 20px rgba(0,0,0,.18); }
    .btn-secondary { background: var(--secondary); color: #fff; }
    .btn-secondary:hover { opacity: .88; transform: translateY(-1px); box-shadow: 0 8px 20px rgba(0,0,0,.18); }
    .btn-outline { background: transparent; color: #fff; border: 2px solid rgba(255,255,255,.5); }
    .btn-outline:hover { background: rgba(255,255,255,.12); border-color: #fff; }

    /* Cards */
    .card { background: #fff; border-radius: 16px; overflow: hidden; transition: transform .25s, box-shadow .25s; box-shadow: 0 1px 4px rgba(0,0,0,.06); }
    .card:hover { transform: translateY(-6px); box-shadow: 0 20px 48px rgba(0,0,0,.11); }

    /* Top bar */
    .topbar { background: var(--primary); border-bottom: 1px solid rgba(255,255,255,.08); }

    /* Nav */
    .main-nav { background: #fff; box-shadow: 0 2px 16px rgba(0,0,0,.06); position: sticky; top: 0; z-index: 100; }
    .nav-link { position: relative; color: #374151; font-weight: 500; font-size: 14px; padding: 6px 4px; text-decoration: none; transition: color .2s; white-space: nowrap; }
    .nav-link::after { content: ''; position: absolute; bottom: -2px; left: 0; width: 0; height: 2px; background: var(--secondary); border-radius: 2px; transition: width .3s; }
    .nav-link:hover { color: var(--primary); }
    .nav-link:hover::after { width: 100%; }
    .nav-link.active { color: var(--primary); font-weight: 600; }
    .nav-link.active::after { width: 100%; }

    /* Lang btn */
    .lang-btn { padding: 4px 11px; border-radius: 5px; font-size: 11px; font-weight: 700; letter-spacing: .04em; transition: all .2s; cursor: pointer; border: none; font-family: 'Inter', sans-serif; }
    .lang-btn.active { background: var(--secondary); color: #fff; }
    .lang-btn:not(.active) { background: rgba(255,255,255,.12); color: rgba(255,255,255,.7); }
    .lang-btn:not(.active):hover { background: rgba(255,255,255,.2); color: #fff; }

    /* Section */
    .section-label { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--secondary); font-family: 'Inter', sans-serif; }
    .section-title { font-size: 2rem; font-weight: 900; color: #0f172a; line-height: 1.2; }

    /* Ticker */
    @keyframes ticker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
    .ticker-track { display: flex; width: max-content; animation: ticker 28s linear infinite; }
    .ticker-track:hover { animation-play-state: paused; }

    /* Page header */
    .page-header { background: linear-gradient(135deg, var(--primary) 0%, #1a3a8f 100%); position: relative; overflow: hidden; }
    .page-header::before { content: ''; position: absolute; inset: 0; background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); }

    /* Badge */
    .badge { display: inline-flex; align-items: center; gap: 5px; padding: 4px 12px; border-radius: 100px; font-size: 11px; font-weight: 600; font-family: 'Inter', sans-serif; }

    /* Divider */
    .divider { width: 48px; height: 3px; background: var(--secondary); border-radius: 2px; margin: 12px 0 20px; }

    /* Mobile menu */
    #mobile-menu { display: none; }
    #mobile-menu.open { display: block; }

    /* Smooth animations */
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
    .animate-fadeInUp { animation: fadeInUp .6s ease both; }
    .delay-100 { animation-delay: .1s; }
    .delay-200 { animation-delay: .2s; }
    .delay-300 { animation-delay: .3s; }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #f1f5f9; }
    ::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 3px; }

    /* Print hide */
    @media print { .main-nav, .topbar, footer { display: none; } }
  </style>
</head>
<body>

<!-- ── Top Bar ── -->
<div class="topbar py-2.5 hidden md:block">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
    <div class="flex items-center gap-6 text-white/70 text-xs">
      <% if(settings.footer_phone){ %>
        <a href="tel:<%= settings.footer_phone %>" class="flex items-center gap-1.5 hover:text-white transition">
          <i class="fas fa-phone-alt text-secondary"></i> <%= settings.footer_phone %>
        </a>
      <% } %>
      <% if(settings.footer_email){ %>
        <a href="mailto:<%= settings.footer_email %>" class="flex items-center gap-1.5 hover:text-white transition">
          <i class="fas fa-envelope text-secondary"></i> <%= settings.footer_email %>
        </a>
      <% } %>
      <% if(settings.footer_address_uz){ %>
        <span class="hidden lg:flex items-center gap-1.5">
          <i class="fas fa-map-marker-alt text-secondary"></i> <%= settings.footer_address_uz %>
        </span>
      <% } %>
    </div>
    <div class="flex items-center gap-4">
      <!-- Social -->
      <div class="flex items-center gap-2">
        <% if(settings.social_telegram){ %>
          <a href="<%= settings.social_telegram %>" target="_blank" class="w-6 h-6 rounded flex items-center justify-center text-white/50 hover:text-white transition text-xs"><i class="fab fa-telegram"></i></a>
        <% } %>
        <% if(settings.social_instagram){ %>
          <a href="<%= settings.social_instagram %>" target="_blank" class="w-6 h-6 rounded flex items-center justify-center text-white/50 hover:text-white transition text-xs"><i class="fab fa-instagram"></i></a>
        <% } %>
        <% if(settings.social_youtube){ %>
          <a href="<%= settings.social_youtube %>" target="_blank" class="w-6 h-6 rounded flex items-center justify-center text-white/50 hover:text-white transition text-xs"><i class="fab fa-youtube"></i></a>
        <% } %>
        <% if(settings.social_facebook){ %>
          <a href="<%= settings.social_facebook %>" target="_blank" class="w-6 h-6 rounded flex items-center justify-center text-white/50 hover:text-white transition text-xs"><i class="fab fa-facebook-f"></i></a>
        <% } %>
      </div>
      <!-- Language -->
      <div class="flex items-center gap-1">
        <a href="?lang=uz" class="lang-btn <%= lang==='uz'?'active':'' %>">UZ</a>
        <a href="?lang=ru" class="lang-btn <%= lang==='ru'?'active':'' %>">RU</a>
        <a href="?lang=en" class="lang-btn <%= lang==='en'?'active':'' %>">EN</a>
      </div>
    </div>
  </div>
</div>

<!-- ── Main Navigation ── -->
<nav class="main-nav">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-center justify-between h-18 py-3">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 flex-shrink-0">
        <% if(settings.logo){ %>
          <img src="<%= settings.logo %>" alt="Logo" class="h-14 w-14 object-contain rounded-xl">
        <% } else { %>
          <div class="w-14 h-14 rounded-xl flex items-center justify-center text-white font-black text-2xl" style="background:var(--primary)">
            <i class="fas fa-graduation-cap"></i>
          </div>
        <% } %>
        <div>
          <p class="font-bold text-gray-900 text-sm leading-tight"><%= settings['site_name_'+lang] || settings.site_name_uz || 'Prezident Maktabi' %></p>
          <p class="text-gray-400 text-xs mt-0.5">
            <% if(lang==='uz'){%>Rasmiy veb-sayt<%}else if(lang==='ru'){%>Официальный сайт<%}else{%>Official website<%}%>
          </p>
        </div>
      </a>

      <!-- Desktop links -->
      <div class="hidden lg:flex items-center gap-7">
        <a href="/" class="nav-link">
          <% if(lang==='uz'){%>Bosh sahifa<%}else if(lang==='ru'){%>Главная<%}else{%>Home<%}%>
        </a>
        <a href="/about" class="nav-link">
          <% if(lang==='uz'){%>Maktab haqida<%}else if(lang==='ru'){%>О школе<%}else{%>About<%}%>
        </a>
        <a href="/news" class="nav-link">
          <% if(lang==='uz'){%>Yangiliklar<%}else if(lang==='ru'){%>Новости<%}else{%>News<%}%>
        </a>
        <a href="/admission" class="nav-link">
          <% if(lang==='uz'){%>Qabul<%}else if(lang==='ru'){%>Приём<%}else{%>Admission<%}%>
        </a>
        <a href="/gallery" class="nav-link">
          <% if(lang==='uz'){%>Galereya<%}else if(lang==='ru'){%>Галерея<%}else{%>Gallery<%}%>
        </a>
        <a href="/budget" class="nav-link">
          <% if(lang==='uz'){%>Budjet<%}else if(lang==='ru'){%>Бюджет<%}else{%>Budget<%}%>
        </a>
        <a href="/contact" class="nav-link">
          <% if(lang==='uz'){%>Aloqa<%}else if(lang==='ru'){%>Контакт<%}else{%>Contact<%}%>
        </a>
      </div>

      <!-- Right -->
      <div class="flex items-center gap-3">
        <div class="flex md:hidden gap-1">
          <a href="?lang=uz" class="lang-btn active-mob text-xs font-bold px-2 py-1 rounded" style="<%= lang==='uz'?'background:var(--primary);color:#fff':'color:#6b7280' %>">UZ</a>
          <a href="?lang=ru" class="text-xs font-bold px-2 py-1 rounded" style="<%= lang==='ru'?'background:var(--primary);color:#fff':'color:#6b7280' %>">RU</a>
          <a href="?lang=en" class="text-xs font-bold px-2 py-1 rounded" style="<%= lang==='en'?'background:var(--primary);color:#fff':'color:#6b7280' %>">EN</a>
        </div>
        <a href="/admission" class="btn btn-secondary hidden md:inline-flex text-sm py-2.5 px-5">
          <i class="fas fa-pen-alt text-xs"></i>
          <% if(lang==='uz'){%>Ariza berish<%}else if(lang==='ru'){%>Подать заявку<%}else{%>Apply Now<%}%>
        </a>
        <button id="burger" onclick="toggleMenu()" class="lg:hidden p-2.5 rounded-lg hover:bg-gray-100 transition">
          <i class="fas fa-bars text-gray-700"></i>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="border-t pt-3 pb-4 space-y-1">
      <% [
        ['/', lang==='uz'?'Bosh sahifa':lang==='ru'?'Главная':'Home'],
        ['/about', lang==='uz'?'Maktab haqida':lang==='ru'?'О школе':'About'],
        ['/news', lang==='uz'?'Yangiliklar':lang==='ru'?'Новости':'News'],
        ['/admission', lang==='uz'?'Qabul':lang==='ru'?'Приём':'Admission'],
        ['/gallery', lang==='uz'?'Galereya':lang==='ru'?'Галерея':'Gallery'],
        ['/budget', lang==='uz'?'Budjet':lang==='ru'?'Бюджет':'Budget'],
        ['/contact', lang==='uz'?'Aloqa':lang==='ru'?'Контакт':'Contact'],
      ].forEach(([href, label]) => { %>
        <a href="<%= href %>" class="block px-4 py-3 rounded-xl text-gray-700 hover:text-primary hover:bg-gray-50 font-medium text-sm transition"><%= label %></a>
      <% }) %>
      <a href="/admission" class="block mx-4 mt-3 py-3 btn-secondary btn rounded-xl text-center justify-center">
        <i class="fas fa-pen-alt"></i>
        <% if(lang==='uz'){%>Ariza berish<%}else if(lang==='ru'){%>Подать заявку<%}else{%>Apply Now<%}%>
      </a>
    </div>
  </div>
</nav>

<!-- Flash -->
<% if(messages.error && messages.error.length){ %>
  <div class="bg-red-50 border-b border-red-100 px-4 py-3 text-red-700 text-center text-sm">
    <i class="fas fa-exclamation-circle mr-1.5"></i><%= messages.error[0] %>
  </div>
<% } %>
<% if(messages.success && messages.success.length){ %>
  <div class="bg-emerald-50 border-b border-emerald-100 px-4 py-3 text-emerald-700 text-center text-sm">
    <i class="fas fa-check-circle mr-1.5"></i><%= messages.success[0] %>
  </div>
<% } %>

<%- body %>

<!-- ── Footer ── -->
<footer style="background:var(--primary)" class="text-white mt-20">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-6 py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <% if(settings.logo){ %>
            <img src="<%= settings.logo %>" alt="Logo" class="h-12 w-12 object-contain rounded-xl brightness-0 invert opacity-80">
          <% } %>
          <div>
            <p class="font-bold text-base"><%= settings['site_name_'+lang] || settings.site_name_uz || 'Prezident Maktabi' %></p>
          </div>
        </div>
        <p class="text-white/55 text-sm leading-relaxed mb-5">
          <% if(lang==='uz'){%>Bilimli avlod — kelajak poydevori. Zamonaviy ta'lim va innovatsiya markazi.<%}else if(lang==='ru'){%>Знающее поколение — основа будущего. Центр современного образования и инноваций.<%}else{%>Educated generation — foundation of the future. Center of modern education and innovation.<%}%>
        </p>
        <div class="flex gap-2">
          <% if(settings.social_telegram){ %>
            <a href="<%= settings.social_telegram %>" target="_blank" class="w-9 h-9 rounded-lg flex items-center justify-center transition" style="background:rgba(255,255,255,.1)" onmouseover="this.style.background='rgba(255,255,255,.2)'" onmouseout="this.style.background='rgba(255,255,255,.1)'"><i class="fab fa-telegram text-sm"></i></a>
          <% } %>
          <% if(settings.social_instagram){ %>
            <a href="<%= settings.social_instagram %>" target="_blank" class="w-9 h-9 rounded-lg flex items-center justify-center transition" style="background:rgba(255,255,255,.1)" onmouseover="this.style.background='rgba(255,255,255,.2)'" onmouseout="this.style.background='rgba(255,255,255,.1)'"><i class="fab fa-instagram text-sm"></i></a>
          <% } %>
          <% if(settings.social_youtube){ %>
            <a href="<%= settings.social_youtube %>" target="_blank" class="w-9 h-9 rounded-lg flex items-center justify-center transition" style="background:rgba(255,255,255,.1)" onmouseover="this.style.background='rgba(255,255,255,.2)'" onmouseout="this.style.background='rgba(255,255,255,.1)'"><i class="fab fa-youtube text-sm"></i></a>
          <% } %>
          <% if(settings.social_facebook){ %>
            <a href="<%= settings.social_facebook %>" target="_blank" class="w-9 h-9 rounded-lg flex items-center justify-center transition" style="background:rgba(255,255,255,.1)" onmouseover="this.style.background='rgba(255,255,255,.2)'" onmouseout="this.style.background='rgba(255,255,255,.1)'"><i class="fab fa-facebook-f text-sm"></i></a>
          <% } %>
        </div>
      </div>

      <!-- Havolalar -->
      <div>
        <h4 class="font-bold text-sm mb-4 text-white/90">
          <% if(lang==='uz'){%>Tezkor havolalar<%}else if(lang==='ru'){%>Быстрые ссылки<%}else{%>Quick Links<%}%>
        </h4>
        <ul class="space-y-2.5">
          <% [
            ['/about', lang==='uz'?'Maktab haqida':lang==='ru'?'О школе':'About School'],
            ['/news', lang==='uz'?'Yangiliklar':lang==='ru'?'Новости':'News'],
            ['/admission', lang==='uz'?'Qabul':lang==='ru'?'Приём':'Admission'],
            ['/gallery', lang==='uz'?'Galereya':lang==='ru'?'Галерея':'Gallery'],
            ['/budget', lang==='uz'?'Budjet shaffofligi':lang==='ru'?'Бюджетная прозрачность':'Budget Transparency'],
          ].forEach(([href, label]) => { %>
            <li><a href="<%= href %>" class="text-white/55 hover:text-white text-sm transition flex items-center gap-2"><i class="fas fa-chevron-right text-xs" style="color:var(--secondary)"></i><%= label %></a></li>
          <% }) %>
        </ul>
      </div>

      <!-- Xizmatlar -->
      <div>
        <h4 class="font-bold text-sm mb-4 text-white/90">
          <% if(lang==='uz'){%>Xizmatlar<%}else if(lang==='ru'){%>Услуги<%}else{%>Services<%}%>
        </h4>
        <ul class="space-y-2.5">
          <% [
            ['/admission', lang==='uz'?'Online ariza':lang==='ru'?'Онлайн заявка':'Online Application'],
            ['/news', lang==='uz'?'Yangiliklar lenti':lang==='ru'?'Лента новостей':'News Feed'],
            ['/gallery', lang==='uz'?'Foto galereya':lang==='ru'?'Фотогалерея':'Photo Gallery'],
            ['/budget', lang==='uz'?'Ochiq budjet':lang==='ru'?'Открытый бюджет':'Open Budget'],
            ['/contact', lang==='uz'?'Murojaat':lang==='ru'?'Обращение':'Contact Us'],
          ].forEach(([href, label]) => { %>
            <li><a href="<%= href %>" class="text-white/55 hover:text-white text-sm transition flex items-center gap-2"><i class="fas fa-chevron-right text-xs" style="color:var(--secondary)"></i><%= label %></a></li>
          <% }) %>
        </ul>
      </div>

      <!-- Aloqa -->
      <div>
        <h4 class="font-bold text-sm mb-4 text-white/90">
          <% if(lang==='uz'){%>Aloqa<%}else if(lang==='ru'){%>Контакт<%}else{%>Contact<%}%>
        </h4>
        <ul class="space-y-3">
          <% if(settings.footer_phone){ %>
            <li class="flex items-start gap-3">
              <span class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background:rgba(255,255,255,.1)"><i class="fas fa-phone-alt text-xs" style="color:var(--secondary)"></i></span>
              <div>
                <p class="text-white/40 text-xs"><% if(lang==='uz'){%>Telefon<%}else if(lang==='ru'){%>Телефон<%}else{%>Phone<%}%></p>
                <a href="tel:<%= settings.footer_phone %>" class="text-white/80 text-sm hover:text-white transition"><%= settings.footer_phone %></a>
              </div>
            </li>
          <% } %>
          <% if(settings.footer_email){ %>
            <li class="flex items-start gap-3">
              <span class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background:rgba(255,255,255,.1)"><i class="fas fa-envelope text-xs" style="color:var(--secondary)"></i></span>
              <div>
                <p class="text-white/40 text-xs">Email</p>
                <a href="mailto:<%= settings.footer_email %>" class="text-white/80 text-sm hover:text-white transition"><%= settings.footer_email %></a>
              </div>
            </li>
          <% } %>
          <% if(settings.footer_address_uz){ %>
            <li class="flex items-start gap-3">
              <span class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background:rgba(255,255,255,.1)"><i class="fas fa-map-marker-alt text-xs" style="color:var(--secondary)"></i></span>
              <div>
                <p class="text-white/40 text-xs"><% if(lang==='uz'){%>Manzil<%}else if(lang==='ru'){%>Адрес<%}else{%>Address<%}%></p>
                <p class="text-white/80 text-sm"><%= settings.footer_address_uz %></p>
              </div>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div style="background:rgba(0,0,0,.2)" class="py-4">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-2">
      <p class="text-white/40 text-xs">
        &copy; <%= new Date().getFullYear() %> <%= settings['site_name_'+lang] || settings.site_name_uz %>.
        <% if(lang==='uz'){%>Barcha huquqlar himoyalangan.<%}else if(lang==='ru'){%>Все права защищены.<%}else{%>All rights reserved.<%}%>
      </p>
      <div class="flex items-center gap-1">
        <a href="?lang=uz" class="lang-btn <%= lang==='uz'?'active':'' %>">UZ</a>
        <a href="?lang=ru" class="lang-btn <%= lang==='ru'?'active':'' %>">RU</a>
        <a href="?lang=en" class="lang-btn <%= lang==='en'?'active':'' %>">EN</a>
      </div>
    </div>
  </div>
</footer>

<!-- Back to top -->
<button id="back-to-top" onclick="window.scrollTo({top:0,behavior:'smooth'})"
  class="fixed bottom-6 right-6 w-11 h-11 rounded-xl text-white shadow-lg z-50 hidden items-center justify-center transition-all"
  style="background:var(--primary)">
  <i class="fas fa-arrow-up text-sm"></i>
</button>

<script>
function toggleMenu() {
  document.getElementById('mobile-menu').classList.toggle('open');
}
// Back to top
window.addEventListener('scroll', () => {
  const btn = document.getElementById('back-to-top');
  if (window.scrollY > 400) { btn.classList.remove('hidden'); btn.classList.add('flex'); }
  else { btn.classList.add('hidden'); btn.classList.remove('flex'); }
});
// Active nav
const path = window.location.pathname;
document.querySelectorAll('.nav-link').forEach(a => {
  if (a.getAttribute('href') === path || (path.startsWith(a.getAttribute('href')) && a.getAttribute('href') !== '/')) {
    a.classList.add('active');
  }
});
</script>
</body>
</html>
