<!-- Header -->
<div class="bg-primary text-white py-16 px-4">
  <div class="max-w-7xl mx-auto">
    <h1 class="text-4xl font-bold mb-3"><% if(lang==='uz'){%>Aloqa<%}else if(lang==='ru'){%>Контакт<%}else{%>Contact Us<%}%></h1>
    <p class="text-white/60 flex items-center gap-2 text-sm">
      <a href="/" class="hover:text-white"><% if(lang==='uz'){%>Bosh sahifa<%}else if(lang==='ru'){%>Главная<%}else{%>Home<%}%></a>
      <i class="fas fa-chevron-right text-xs"></i>
      <span><% if(lang==='uz'){%>Aloqa<%}else if(lang==='ru'){%>Контакт<%}else{%>Contact<%}%></span>
    </p>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 py-14">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    <!-- Contact Info -->
    <div class="space-y-5">
      <% if (settings.footer_phone) { %>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-start gap-4">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
            <i class="fas fa-phone text-blue-600"></i>
          </div>
          <div>
            <p class="font-semibold text-gray-900 mb-1"><% if(lang==='uz'){%>Telefon<%}else if(lang==='ru'){%>Телефон<%}else{%>Phone<%}%></p>
            <p class="text-gray-600 text-sm"><%= settings.footer_phone %></p>
          </div>
        </div>
      <% } %>
      <% if (settings.footer_email) { %>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-start gap-4">
          <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center flex-shrink-0">
            <i class="fas fa-envelope text-green-600"></i>
          </div>
          <div>
            <p class="font-semibold text-gray-900 mb-1">Email</p>
            <p class="text-gray-600 text-sm"><%= settings.footer_email %></p>
          </div>
        </div>
      <% } %>
      <% if (settings.footer_address_uz) { %>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-start gap-4">
          <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center flex-shrink-0">
            <i class="fas fa-map-marker-alt text-orange-600"></i>
          </div>
          <div>
            <p class="font-semibold text-gray-900 mb-1"><% if(lang==='uz'){%>Manzil<%}else if(lang==='ru'){%>Адрес<%}else{%>Address<%}%></p>
            <p class="text-gray-600 text-sm"><%= settings.footer_address_uz %></p>
          </div>
        </div>
      <% } %>

      <!-- Working Hours -->
      <div class="bg-primary rounded-2xl p-6 text-white">
        <h3 class="font-bold mb-4 flex items-center gap-2">
          <i class="fas fa-clock text-secondary"></i>
          <% if(lang==='uz'){%>Ish vaqti<%}else if(lang==='ru'){%>Часы работы<%}else{%>Working Hours<%}%>
        </h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-white/70"><% if(lang==='uz'){%>Du-Ju<%}else if(lang==='ru'){%>Пн-Пт<%}else{%>Mon-Fri<%}%></span>
            <span>9:00 - 18:00</span>
          </div>
          <div class="flex justify-between">
            <span class="text-white/70"><% if(lang==='uz'){%>Shanba<%}else if(lang==='ru'){%>Суббота<%}else{%>Saturday<%}%></span>
            <span>9:00 - 14:00</span>
          </div>
          <div class="flex justify-between">
            <span class="text-white/70"><% if(lang==='uz'){%>Yakshanba<%}else if(lang==='ru'){%>Воскресенье<%}else{%>Sunday<%}%></span>
            <span class="text-white/50"><% if(lang==='uz'){%>Yopiq<%}else if(lang==='ru'){%>Закрыто<%}else{%>Closed<%}%></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="lg:col-span-2">
      <div class="bg-white rounded-2xl shadow-sm p-8 border border-gray-100">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">
          <% if(lang==='uz'){%>Xabar yuborish<%}else if(lang==='ru'){%>Отправить сообщение<%}else{%>Send a Message<%}%>
        </h2>
        <p class="text-gray-500 text-sm mb-7">
          <% if(lang==='uz'){%>Savollaringizni yozing, tez orada javob beramiz<%}else if(lang==='ru'){%>Напишите ваши вопросы, мы ответим вам в ближайшее время<%}else{%>Write your questions and we'll get back to you soon<%}%>
        </p>

        <form method="POST" action="/message" class="space-y-5">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">
                <% if(lang==='uz'){%>Ismingiz *<%}else if(lang==='ru'){%>Ваше имя *<%}else{%>Your Name *<%}%>
              </label>
              <input type="text" name="name" required class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition">
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Email *</label>
              <input type="email" name="email" required class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition">
            </div>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              <% if(lang==='uz'){%>Xabar *<%}else if(lang==='ru'){%>Сообщение *<%}else{%>Message *<%}%>
            </label>
            <textarea name="message" required rows="6" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition resize-none" placeholder="<% if(lang==='uz'){%>Xabaringizni yozing...<%}else if(lang==='ru'){%>Напишите ваше сообщение...<%}else{%>Write your message...<%}%>"></textarea>
          </div>
          <button type="submit" class="w-full py-4 bg-primary text-white rounded-xl font-bold text-lg hover:opacity-90 transition shadow-lg shadow-primary/20 flex items-center justify-center gap-2">
            <i class="fas fa-paper-plane"></i>
            <% if(lang==='uz'){%>Xabar yuborish<%}else if(lang==='ru'){%>Отправить сообщение<%}else{%>Send Message<%}%>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
