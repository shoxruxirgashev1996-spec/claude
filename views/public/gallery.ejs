<div class="page-header py-16 px-6">
  <div class="max-w-7xl mx-auto relative z-10">
    <div class="flex items-center gap-2 text-white/50 text-xs mb-4">
      <a href="/" class="hover:text-white"><% if(lang==='uz'){%>Bosh sahifa<%}else if(lang==='ru'){%>Главная<%}else{%>Home<%}%></a>
      <i class="fas fa-chevron-right text-xs"></i>
      <span class="text-white/80"><% if(lang==='uz'){%>Galereya<%}else if(lang==='ru'){%>Галерея<%}else{%>Gallery<%}%></span>
    </div>
    <h1 class="text-white text-4xl font-black"><% if(lang==='uz'){%>Foto va Video galereya<%}else if(lang==='ru'){%>Фото и Видеогалерея<%}else{%>Photo & Video Gallery<%}%></h1>
  </div>
</div>

<div class="max-w-7xl mx-auto px-6 py-12">
  <!-- Filters -->
  <div class="flex flex-wrap gap-2 mb-10">
    <a href="/gallery" class="badge text-sm font-semibold transition" style="<%= !query.category?'background:var(--primary);color:#fff':'background:#fff;color:#374151;border:1px solid #e5e7eb' %>">
      <% if(lang==='uz'){%>Barchasi<%}else if(lang==='ru'){%>Все<%}else{%>All<%}%> (<%= gallery.length %>)
    </a>
    <% categories.forEach(cat => { %>
      <a href="/gallery?category=<%= cat %>" class="badge text-sm font-semibold capitalize transition"
        style="<%= query.category===cat?'background:var(--primary);color:#fff':'background:#fff;color:#374151;border:1px solid #e5e7eb' %>">
        <%= cat %>
      </a>
    <% }) %>
  </div>

  <% if(!gallery || gallery.length===0){ %>
    <div class="text-center py-24 bg-white rounded-2xl border border-gray-100">
      <i class="fas fa-images text-5xl text-gray-200 mb-4 block"></i>
      <p class="text-gray-400 font-medium text-lg"><% if(lang==='uz'){%>Galereya bo'sh<%}else if(lang==='ru'){%>Галерея пуста<%}else{%>Gallery is empty<%}%></p>
    </div>
  <% } else { %>
  <!-- Masonry Grid -->
  <div class="columns-2 md:columns-3 lg:columns-4 gap-4 space-y-0">
    <% gallery.forEach((item, i) => { %>
      <div class="break-inside-avoid mb-4">
        <% if(item.type==='video' || item.video_url){ %>
          <div class="relative rounded-2xl overflow-hidden bg-gray-900 cursor-pointer group"
            onclick="openVideoModal('<%= item.video_url %>', '<%= (item['title_'+lang]||item.title_uz||'').replace(/'/g,\"'\") %>')">
            <div class="aspect-video flex items-center justify-center" style="background:linear-gradient(135deg,#0f172a,#1e3a5f)">
              <div class="text-center">
                <div class="w-16 h-16 rounded-full bg-white/10 backdrop-blur flex items-center justify-center mx-auto mb-3 group-hover:bg-white/20 transition">
                  <i class="fas fa-play text-white text-xl ml-1"></i>
                </div>
                <p class="text-white/70 text-xs"><% if(lang==='uz'){%>Video ko'rish<%}else if(lang==='ru'){%>Смотреть видео<%}else{%>Watch Video<%}%></p>
              </div>
            </div>
            <% if(item['title_'+lang]||item.title_uz){ %>
              <div class="absolute bottom-0 left-0 right-0 p-3" style="background:linear-gradient(transparent,rgba(0,0,0,.7))">
                <p class="text-white text-xs font-medium truncate"><%= item['title_'+lang]||item.title_uz %></p>
              </div>
            <% } %>
            <span class="absolute top-2 right-2 badge text-white text-xs" style="background:rgba(239,68,68,.9)">
              <i class="fab fa-youtube text-xs mr-1"></i>Video
            </span>
          </div>
        <% } else { %>
          <div class="relative overflow-hidden rounded-2xl group cursor-pointer"
            onclick="openLightbox('<%= item.image %>', '<%= (item['title_'+lang]||item.title_uz||'').replace(/'/g,\"'\") %>')">
            <img src="<%= item.image %>" alt="<%= item['title_'+lang]||'' %>"
              class="w-full object-cover group-hover:scale-105 transition-transform duration-500">
            <div class="absolute inset-0 flex items-end justify-between p-3 opacity-0 group-hover:opacity-100 transition-opacity"
              style="background:linear-gradient(transparent,rgba(0,0,0,.55))">
              <% if(item['title_'+lang]||item.title_uz){ %>
                <p class="text-white text-xs font-medium"><%= item['title_'+lang]||item.title_uz %></p>
              <% } %>
              <div class="w-8 h-8 rounded-full bg-white/20 backdrop-blur flex items-center justify-center flex-shrink-0">
                <i class="fas fa-expand-alt text-white text-xs"></i>
              </div>
            </div>
            <% if(item.category){ %>
              <span class="absolute top-2 left-2 badge text-white text-xs capitalize" style="background:rgba(0,0,0,.45);backdrop-filter:blur(4px)"><%= item.category %></span>
            <% } %>
          </div>
        <% } %>
      </div>
    <% }) %>
  </div>
  <% } %>
</div>

<!-- Image Lightbox -->
<div id="lightbox" class="fixed inset-0 z-[200] hidden items-center justify-center p-4" style="background:rgba(0,0,0,.94)" onclick="if(event.target===this)closeLightbox()">
  <button onclick="closeLightbox()" class="absolute top-5 right-5 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition z-10">
    <i class="fas fa-times"></i>
  </button>
  <div class="text-center max-w-5xl w-full">
    <img id="lb-img" src="" class="max-w-full max-h-[85vh] rounded-2xl object-contain shadow-2xl mx-auto">
    <p id="lb-caption" class="text-white/60 text-sm mt-3"></p>
  </div>
</div>

<!-- Video Modal -->
<div id="video-modal" class="fixed inset-0 z-[200] hidden items-center justify-center p-4" style="background:rgba(0,0,0,.94)" onclick="if(event.target===this)closeVideo()">
  <button onclick="closeVideo()" class="absolute top-5 right-5 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition z-10">
    <i class="fas fa-times"></i>
  </button>
  <div class="w-full max-w-4xl">
    <p id="video-title" class="text-white font-bold text-lg mb-4"></p>
    <div class="aspect-video rounded-2xl overflow-hidden bg-black">
      <iframe id="video-frame" src="" class="w-full h-full" allowfullscreen frameborder="0" allow="autoplay"></iframe>
    </div>
  </div>
</div>

<script>
function openLightbox(src, caption) {
  document.getElementById('lb-img').src = src;
  document.getElementById('lb-caption').textContent = caption || '';
  const lb = document.getElementById('lightbox');
  lb.classList.remove('hidden'); lb.classList.add('flex');
  document.body.style.overflow = 'hidden';
}
function closeLightbox() {
  const lb = document.getElementById('lightbox');
  lb.classList.add('hidden'); lb.classList.remove('flex');
  document.body.style.overflow = '';
}
function openVideoModal(url, title) {
  // YouTube URL ni embed formatga o'tkazish
  let embedUrl = url;
  if (url.includes('youtube.com/watch?v=')) {
    const id = url.split('v=')[1].split('&')[0];
    embedUrl = 'https://www.youtube.com/embed/' + id + '?autoplay=1';
  } else if (url.includes('youtu.be/')) {
    const id = url.split('youtu.be/')[1].split('?')[0];
    embedUrl = 'https://www.youtube.com/embed/' + id + '?autoplay=1';
  }
  document.getElementById('video-frame').src = embedUrl;
  document.getElementById('video-title').textContent = title || '';
  const m = document.getElementById('video-modal');
  m.classList.remove('hidden'); m.classList.add('flex');
  document.body.style.overflow = 'hidden';
}
function closeVideo() {
  document.getElementById('video-frame').src = '';
  const m = document.getElementById('video-modal');
  m.classList.add('hidden'); m.classList.remove('flex');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') { closeLightbox(); closeVideo(); }
});
</script>
