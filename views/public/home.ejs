          <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity" style="background:rgba(15,42,94,.5)">
            <div class="w-12 h-12 rounded-full bg-white/20 backdrop-blur flex items-center justify-center">
              <i class="fas fa-expand-alt text-white"></i>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- ── CTA Banner ── -->
<section class="py-20 px-6 relative overflow-hidden" style="background:var(--primary)">
  <div class="absolute inset-0">
    <div class="absolute top-0 right-0 w-80 h-80 rounded-full opacity-5" style="background:var(--secondary);transform:translate(40px,-40px)"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full opacity-5" style="background:#fff;transform:translate(-30px,30px)"></div>
  </div>
  <div class="max-w-4xl mx-auto text-center relative z-10">
    <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-6" style="background:rgba(255,255,255,.1)">
      <i class="fas fa-graduation-cap text-2xl" style="color:var(--secondary)"></i>
    </div>
    <h2 class="text-white text-3xl md:text-4xl font-black mb-4">
      <% if(lang==='uz'){%>Kelajagingizni bugun boshlang!<%}else if(lang==='ru'){%>Начните своё будущее сегодня!<%}else{%>Start Your Future Today!<%}%>
    </h2>
    <p class="text-white/65 text-lg mb-10 max-w-xl mx-auto">
