<!-- ── Announcement Ticker ── -->
<% if(announcements && announcements.length){ %>
<div style="background:var(--secondary)" class="py-2.5 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 flex items-center gap-4">
    <span class="flex-shrink-0 text-white text-xs font-bold uppercase tracking-wider flex items-center gap-2 bg-white/20 px-3 py-1.5 rounded-full">
      <i class="fas fa-bullhorn text-xs"></i>
      <% if(lang==='uz'){%>E'lon<%}else if(lang==='ru'){%>Объявление<%}else{%>Notice<%}%>
    </span>
    <div class="overflow-hidden flex-1">
      <div class="ticker-track text-white text-sm">
        <% [1,2].forEach(() => { announcements.forEach(a => { %>
          <span class="mx-12 flex-shrink-0">
            <i class="fas fa-circle text-white/30 mr-2 text-xs"></i>
            <%= a['title_'+lang] || a.title_uz %>
          </span>
        <% }) }) %>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- ── Hero Section ── -->
<section class="relative overflow-hidden" style="min-height:560px;display:flex;align-items:center;
  <% if(settings.bg_type==='image' && settings.banner_image){ %>
    background: linear-gradient(135deg, rgba(10,28,70,.88) 0%, rgba(15,42,94,.78) 100%), url('<%= settings.banner_image %>') center/cover no-repeat;
  <% } else { %>
    background: linear-gradient(135deg, var(--primary) 0%, #1a3a8f 55%, #0d1f52 100%);
  <% } %>">

  <!-- Geometric shapes -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-20 -right-20 w-96 h-96 rounded-full opacity-5" style="background:var(--secondary)"></div>
    <div class="absolute -bottom-32 -left-20 w-80 h-80 rounded-full opacity-5" style="background:#fff"></div>
    <svg class="absolute inset-0 w-full h-full opacity-4" xmlns="http://www.w3.org/2000/svg">
      <defs><pattern id="grid" width="50" height="50" patternUnits="userSpaceOnUse"><path d="M 50 0 L 0 0 0 50" fill="none" stroke="white" stroke-width=".6"/></pattern></defs>
      <rect width="100%" height="100%" fill="url(#grid)"/>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-6 py-24 w-full relative z-10">
    <div class="max-w-3xl">
      <div class="animate-fadeInUp">
        <span class="badge mb-5 text-white" style="background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2)">
          <i class="fas fa-award" style="color:var(--secondary)"></i>
          <% if(lang==='uz'){%>O'zbekiston Prezident Maktablari<%}else if(lang==='ru'){%>Президентские школы Узбекистана<%}else{%>Presidential Schools of Uzbekistan<%}%>
        </span>
      </div>
      <h1 class="text-white text-4xl md:text-6xl font-black leading-tight mb-5 animate-fadeInUp delay-100">
        <%= settings['banner_title_'+lang] || settings.banner_title_uz ||
          (lang==='uz'?'Bilimli avlod —<br>kelajak poydevori':lang==='ru'?'Знающее поколение —<br>основа будущего':'Educated Generation —<br>Foundation of the Future') %>
      </h1>
      <p class="text-white/70 text-lg md:text-xl leading-relaxed mb-10 max-w-xl animate-fadeInUp delay-200">
        <%= settings['banner_subtitle_'+lang] || settings.banner_subtitle_uz ||
          (lang==='uz'?"Zamonaviy ta'lim, ilm va innovatsiya markazi":lang==='ru'?'Центр современного образования, науки и инноваций':'Center of modern education, science and innovation') %>
      </p>
      <div class="flex flex-wrap gap-4 animate-fadeInUp delay-300">
        <a href="/admission" class="btn btn-secondary text-base px-8 py-4">
          <i class="fas fa-pen-alt"></i>
          <% if(lang==='uz'){%>Ariza topshirish<%}else if(lang==='ru'){%>Подать заявку<%}else{%>Apply Now<%}%>
        </a>
        <a href="/about" class="btn btn-outline text-base px-8 py-4">
          <i class="fas fa-play-circle"></i>
          <% if(lang==='uz'){%>Maktab haqida<%}else if(lang==='ru'){%>О школе<%}else{%>About School<%}%>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ── Stats ── -->
<% if(stats && (stats.students_count || stats.teachers_count || stats.awards_count || stats.graduates_count)){ %>
<section class="relative z-10">
  <div class="max-w-5xl mx-auto px-6">
    <div class="bg-white rounded-2xl shadow-xl -mt-10 grid grid-cols-2 md:grid-cols-4 divide-x divide-gray-100 overflow-hidden border border-gray-100">
      <% const statItems = [
        {val: stats.students_count, icon:'fa-user-graduate', uz:"O'quvchilar", ru:'Учеников', en:'Students'},
        {val: stats.teachers_count, icon:'fa-chalkboard-teacher', uz:"O'qituvchilar", ru:'Учителей', en:'Teachers'},
        {val: stats.awards_count, icon:'fa-medal', uz:'Mukofotlar', ru:'Наград', en:'Awards'},
        {val: stats.graduates_count, icon:'fa-scroll', uz:'Bitiruvchilar', ru:'Выпускников', en:'Graduates'},
      ].filter(s => s.val); %>
      <% statItems.forEach((s, i) => { %>
        <div class="p-6 text-center group">
          <div class="w-12 h-12 rounded-xl mx-auto mb-3 flex items-center justify-center transition group-hover:scale-110" style="background:var(--primary-light)">
            <i class="fas <%= s.icon %> text-xl" style="color:var(--primary)"></i>
          </div>
          <p class="text-3xl font-black" style="color:var(--primary)"><%= s.val.toLocaleString() %>+</p>
          <p class="text-gray-500 text-xs font-medium mt-1"><%= s[lang] || s.uz %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- ── Latest News ── -->
<section class="py-20 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="section-label mb-2"><% if(lang==='uz'){%>So'nggi voqealar<%}else if(lang==='ru'){%>Последние события<%}else{%>Latest Updates<%}%></p>
        <h2 class="section-title"><% if(lang==='uz'){%>Yangiliklar<%}else if(lang==='ru'){%>Новости<%}else{%>News & Events<%}%></h2>
        <div class="divider"></div>
      </div>
      <a href="/news" class="btn btn-primary hidden md:inline-flex py-2.5 px-5 text-sm">
        <% if(lang==='uz'){%>Barchasi<%}else if(lang==='ru'){%>Все новости<%}else{%>View All<%}%>
        <i class="fas fa-arrow-right text-xs"></i>
      </a>
    </div>

    <% if(!latestNews || latestNews.length===0){ %>
      <div class="text-center py-20 bg-white rounded-2xl border border-gray-100">
        <i class="fas fa-newspaper text-5xl text-gray-200 mb-4 block"></i>
        <p class="text-gray-400 font-medium"><% if(lang==='uz'){%>Yangiliklar hali yo'q<%}else if(lang==='ru'){%>Новостей пока нет<%}else{%>No news yet<%}%></p>
      </div>
    <% } else { %>
    <!-- Featured + Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Featured (first news) -->
      <% const featured = latestNews[0]; %>
      <div class="lg:col-span-1 card group">
        <div class="relative h-64 overflow-hidden bg-gray-100">
          <% if(featured.image){ %>
            <img src="<%= featured.image %>" alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <% } else { %>
            <div class="w-full h-full flex items-center justify-center" style="background:linear-gradient(135deg,#f0f4ff,#dde5ff)">
              <i class="fas fa-newspaper text-5xl opacity-20" style="color:var(--primary)"></i>
            </div>
          <% } %>
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <span class="badge text-white text-xs mb-2" style="background:var(--secondary)"><%= featured.category %></span>
            <h3 class="text-white font-bold text-lg leading-snug line-clamp-2">
              <%= featured['title_'+lang] || featured.title_uz %>
            </h3>
          </div>
        </div>
        <div class="p-5">
          <p class="text-gray-500 text-sm line-clamp-3 mb-4"><%= (featured['excerpt_'+lang] || featured['content_'+lang] || '').substring(0,140) %>...</p>
          <div class="flex items-center justify-between">
            <span class="text-gray-400 text-xs"><i class="far fa-calendar mr-1.5"></i><%= featured.createdAt.toLocaleDateString() %></span>
            <a href="/news/<%= featured.slug %>" class="text-sm font-semibold flex items-center gap-1 hover:gap-2 transition-all" style="color:var(--primary)">
              <% if(lang==='uz'){%>O'qish<%}else if(lang==='ru'){%>Читать<%}else{%>Read<%}%> <i class="fas fa-arrow-right text-xs"></i>
            </a>
          </div>
        </div>
      </div>

      <!-- Other news -->
      <div class="lg:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-5">
        <% latestNews.slice(1, 5).forEach(n => { %>
          <div class="card group">
            <div class="h-44 overflow-hidden bg-gray-100">
              <% if(n.image){ %>
                <img src="<%= n.image %>" alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
              <% } else { %>
                <div class="w-full h-full flex items-center justify-center" style="background:linear-gradient(135deg,#f8faff,#eef2ff)">
                  <i class="fas fa-newspaper text-3xl opacity-20" style="color:var(--primary)"></i>
                </div>
              <% } %>
            </div>
            <div class="p-4">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs font-semibold capitalize" style="color:var(--secondary)"><%= n.category %></span>
                <span class="text-gray-300 text-xs">•</span>
                <span class="text-gray-400 text-xs"><%= n.createdAt.toLocaleDateString() %></span>
              </div>
              <h3 class="font-bold text-gray-900 text-sm leading-snug line-clamp-2 mb-3">
                <%= n['title_'+lang] || n.title_uz %>
              </h3>
              <a href="/news/<%= n.slug %>" class="text-xs font-semibold flex items-center gap-1 hover:gap-2 transition-all" style="color:var(--primary)">
                <% if(lang==='uz'){%>Batafsil<%}else if(lang==='ru'){%>Подробнее<%}else{%>Read More<%}%> <i class="fas fa-arrow-right"></i>
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <div class="text-center mt-8 md:hidden">
      <a href="/news" class="btn btn-primary">
        <% if(lang==='uz'){%>Barcha yangiliklar<%}else if(lang==='ru'){%>Все новости<%}else{%>All News<%}%>
        <i class="fas fa-arrow-right text-xs"></i>
      </a>
    </div>
  </div>
</section>

<!-- ── Why Us ── -->
<section class="py-16 px-6" style="background:linear-gradient(135deg,#f8f9ff,#f0f4ff)">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <p class="section-label mb-2"><% if(lang==='uz'){%>Nima uchun biz?<%}else if(lang==='ru'){%>Почему мы?<%}else{%>Why Choose Us?<%}%></p>
      <h2 class="section-title"><% if(lang==='uz'){%>Bizning afzalliklarimiz<%}else if(lang==='ru'){%>Наши преимущества<%}else{%>Our Advantages<%}%></h2>
      <div class="divider mx-auto"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <% const features = [
        { icon:'fa-brain', color:'#6366f1', bgColor:'#eef2ff',
          uz:"Zamonaviy ta'lim", ru:'Современное образование', en:'Modern Education',
          duz:"STEM fanlariga asoslangan chuqur va keng qamrovli o'quv dasturi",
          dru:'Глубокая программа обучения, основанная на STEM науках',
          den:'Deep and comprehensive curriculum based on STEM sciences' },
        { icon:'fa-users', color:'#10b981', bgColor:'#ecfdf5',
          uz:"Tajribali o'qituvchilar", ru:'Опытные учителя', en:'Expert Teachers',
          duz:"Yuqori malakali va fidokor o'qituvchilar jamoasi",
          dru:'Команда высококвалифицированных и преданных учителей',
          den:'Highly qualified and dedicated team of teachers' },
        { icon:'fa-trophy', color:'#f59e0b', bgColor:'#fffbeb',
          uz:'Xalqaro muvaffaqiyatlar', ru:'Международные достижения', en:'International Achievements',
          duz:"Xalqaro olimpiadalar va musobaqalarda o'quvchilarimizning yutuqlari",
          dru:'Достижения наших учеников на международных олимпиадах',
          den:'Achievements of our students at international olympiads' },
        { icon:'fa-building', color:'#3b82f6', bgColor:'#eff6ff',
          uz:'Zamonaviy infratuzilma', ru:'Современная инфраструктура', en:'Modern Infrastructure',
          duz:"Eng zamonaviy laboratoriyalar, kutubxona va sport inshootlari",
          dru:'Современные лаборатории, библиотека и спортивные сооружения',
          den:'State-of-the-art laboratories, library and sports facilities' },
      ] %>
      <% features.forEach(f => { %>
        <div class="card p-6 text-center group">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-5 transition group-hover:scale-110" style="background:<%= f.bgColor %>">
            <i class="fas <%= f.icon %> text-2xl" style="color:<%= f.color %>"></i>
          </div>
          <h3 class="font-bold text-gray-900 text-base mb-2"><%= f[lang] || f.uz %></h3>
          <p class="text-gray-500 text-sm leading-relaxed"><%= f['d'+lang] || f.duz %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ── Gallery ── -->
<% if(gallery && gallery.length > 0){ %>
<section class="py-20 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="section-label mb-2"><% if(lang==='uz'){%>Hayot lahzalari<%}else if(lang==='ru'){%>Моменты жизни<%}else{%>Moments of Life<%}%></p>
        <h2 class="section-title"><% if(lang==='uz'){%>Foto galereya<%}else if(lang==='ru'){%>Фотогалерея<%}else{%>Photo Gallery<%}%></h2>
        <div class="divider"></div>
      </div>
      <a href="/gallery" class="btn btn-primary hidden md:inline-flex py-2.5 px-5 text-sm">
        <% if(lang==='uz'){%>Barchasi<%}else if(lang==='ru'){%>Все фото<%}else{%>View All<%}%>
        <i class="fas fa-arrow-right text-xs"></i>
      </a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <% gallery.slice(0,8).forEach((img, i) => { %>
